<m>      </m><a-stmt><E-1><named-E><N><n>MSG</n></N></named-E></E-1> <a>=</a> <E-2><string-E><S>'BONJOUR'</S></string-E></E-2></a-stmt>

<C>C     WRITE avec numero de format</C>
<m>      </m><write-stmt>WRITE(<io-control-spec><io-control><literal-E><l>6</l></literal-E></io-control>, <io-control><literal-E><l>100</l></literal-E></io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>I</n></N></named-E></output-item>, <output-item><named-E><N><n>X</n></N></named-E></output-item></output-item-LT></write-stmt>
