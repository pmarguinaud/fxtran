<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FIXED" source-width="72" openmp="0" openacc="0" openmp-target="0"><file name="f77_10_io_write.f"><C>C     Test: entrees/sorties - WRITE, PRINT, FORMAT</C>
