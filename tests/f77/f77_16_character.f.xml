<m>      </m><program-stmt>PROGRAM <program-N><N><n>CHARTEST</n></N></program-N></program-stmt>
<m>      </m><implicit-none-stmt>IMPLICIT NONE</implicit-none-stmt>

<m>      </m><T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>CHARACTER</T-N><char-selector>*<literal-E><l>20</l></literal-E></char-selector></intrinsic-T-spec></_T-spec_> <EN-decl-LT><EN-decl><EN-N><N><n>STR1</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>STR2</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>STR3</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
<m>      </m><T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>CHARACTER</T-N><char-selector>*<literal-E><l>5</l></literal-E></char-selector></intrinsic-T-spec></_T-spec_>  <EN-decl-LT><EN-decl><EN-N><N><n>SUB1</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
<m>      </m><T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>CHARACTER</T-N><char-selector>*<literal-E><l>1</l></literal-E></char-selector></intrinsic-T-spec></_T-spec_>  <EN-decl-LT><EN-decl><EN-N><N><n>CH</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
<m>      </m><T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>INTEGER</T-N></intrinsic-T-spec></_T-spec_>      <EN-decl-LT><EN-decl><EN-N><N><n>ILEN</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>I</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>

<C>C     Affectation de chaines</C>
<m>      </m><a-stmt><E-1><named-E><N><n>STR1</n></N></named-E></E-1> <a>=</a> <E-2><string-E><S>'HELLO'</S></string-E></E-2></a-stmt>
<m>      </m><a-stmt><E-1><named-E><N><n>STR2</n></N></named-E></E-1> <a>=</a> <E-2><string-E><S>' WORLD'</S></string-E></E-2></a-stmt>

<C>C     Concatenation //</C>
<m>      </m><a-stmt><E-1><named-E><N><n>STR3</n></N></named-E></E-1> <a>=</a> <E-2><op-E><named-E><N><n>STR1</n></N></named-E> <op><o>//</o></op> <named-E><N><n>STR2</n></N></named-E></op-E></E-2></a-stmt>

<C>C     Sous-chaine (substring) : extraction par indices</C>
<m>      </m><a-stmt><E-1><named-E><N><n>SUB1</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>STR3</n></N><R-LT><array-R>(<section-subscript-LT><section-subscript><lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><literal-E><l>5</l></literal-E></upper-bound></section-subscript></section-subscript-LT>)</array-R></R-LT></named-E></E-2></a-stmt>

<C>C     Sous-chaine : affectation dans une sous-chaine</C>
<m>      </m><a-stmt><E-1><named-E><N><n>STR3</n></N><R-LT><array-R>(<section-subscript-LT><section-subscript><lower-bound><literal-E><l>7</l></literal-E></lower-bound>:<upper-bound><literal-E><l>11</l></literal-E></upper-bound></section-subscript></section-subscript-LT>)</array-R></R-LT></named-E></E-1> <a>=</a> <E-2><string-E><S>'WORLD'</S></string-E></E-2></a-stmt>

<C>C     Caractere unique</C>
<m>      </m><a-stmt><E-1><named-E><N><n>CH</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>STR1</n></N><R-LT><array-R>(<section-subscript-LT><section-subscript><lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><literal-E><l>1</l></literal-E></upper-bound></section-subscript></section-subscript-LT>)</array-R></R-LT></named-E></E-2></a-stmt>

<C>C     Comparaison de chaines (op&#195;&#169;rateurs relationnels)</C>
<m>      </m><if-stmt>IF (<condition-E><op-E><named-E><N><n>STR1</n></N></named-E> <op><o>.EQ.</o></op> <string-E><S>'HELLO'</S></string-E></op-E></condition-E>) <action-stmt><write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'EGAL'</S></string-E></output-item></output-item-LT></write-stmt></action-stmt></if-stmt>
<m>      </m><if-stmt>IF (<condition-E><op-E><named-E><N><n>STR1</n></N></named-E> <op><o>.NE.</o></op> <named-E><N><n>STR2</n></N></named-E></op-E></condition-E>)    <action-stmt><write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'DIFFERENT'</S></string-E></output-item></output-item-LT></write-stmt></action-stmt></if-stmt>
<m>      </m><if-stmt>IF (<condition-E><op-E><named-E><N><n>STR1</n></N></named-E> <op><o>.LT.</o></op> <named-E><N><n>STR2</n></N></named-E></op-E></condition-E>)    <action-stmt><write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'INFERIEUR'</S></string-E></output-item></output-item-LT></write-stmt></action-stmt></if-stmt>
<m>      </m><if-stmt>IF (<condition-E><op-E><named-E><N><n>STR2</n></N></named-E> <op><o>.GT.</o></op> <named-E><N><n>STR1</n></N></named-E></op-E></condition-E>)    <action-stmt><write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'SUPERIEUR'</S></string-E></output-item></output-item-LT></write-stmt></action-stmt></if-stmt>

<C>C     Fonction LEN : longueur declaree</C>
<m>      </m><a-stmt><E-1><named-E><N><n>ILEN</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>LEN</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>STR1</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
<m>      </m><write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'LEN='</S></string-E></output-item>, <output-item><named-E><N><n>ILEN</n></N></named-E></output-item></output-item-LT></write-stmt>

<C>C     Fonction INDEX : position d'une sous-chaine</C>
<m>      </m><a-stmt><E-1><named-E><N><n>I</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>INDEX</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>STR3</n></N></named-E></element>, <element><string-E><S>'WOR'</S></string-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
<m>      </m><write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'INDEX='</S></string-E></output-item>, <output-item><named-E><N><n>I</n></N></named-E></output-item></output-item-LT></write-stmt>

<C>C     Boucle sur les caracteres</C>
<m>      </m><do-label-stmt>DO <label>10</label> <do-V><named-E><N><n>I</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>, <upper-bound><literal-E><l>5</l></literal-E></upper-bound></do-label-stmt>
<m>      </m>  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>STR1</n></N><R-LT><array-R>(<section-subscript-LT><section-subscript><lower-bound><named-E><N><n>I</n></N></named-E></lower-bound>:<upper-bound><named-E><N><n>I</n></N></named-E></upper-bound></section-subscript></section-subscript-LT>)</array-R></R-LT></named-E></output-item></output-item-LT></write-stmt>
<m>   </m><label>10</label><m> </m><continue-stmt>CONTINUE</continue-stmt>

