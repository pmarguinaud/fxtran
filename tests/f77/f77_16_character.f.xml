<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FIXED" source-width="72" openmp="0" openacc="0" openmp-target="0"><file name="f77_16_character.f"><C>C     Test: operations sur les chaines de caracteres</C>
<C>C     Statements couverts: concatenation //, sous-chaines, comparaison,</C>
