  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'INT64 KIND:'</S></string-E></output-item>, <output-item><named-E><N><n>INT64</n></N></named-E></output-item></output-item-LT></write-stmt>

  <C>! Utilisation des types a precision garantie</C>
  <a-stmt><E-1><named-E><N><n>R32</n></N></named-E></E-1>  <a>=</a> <E-2><literal-E><l>3.14</l><K-spec>_<N><n>REAL32</n></N></K-spec></literal-E></E-2></a-stmt>
  <a-stmt><E-1><named-E><N><n>R64</n></N></named-E></E-1>  <a>=</a> <E-2><literal-E><l>3.14159265358979</l><K-spec>_<N><n>REAL64</n></N></K-spec></literal-E></E-2></a-stmt>
  <a-stmt><E-1><named-E><N><n>R128</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>3.14159265358979323846</l><K-spec>_<N><n>REAL128</n></N></K-spec></literal-E></E-2></a-stmt>
  <a-stmt><E-1><named-E><N><n>I8</n></N></named-E></E-1>   <a>=</a> <E-2><literal-E><l>127</l><K-spec>_<N><n>INT8</n></N></K-spec></literal-E></E-2></a-stmt>
  <a-stmt><E-1><named-E><N><n>I16</n></N></named-E></E-1>  <a>=</a> <E-2><literal-E><l>32767</l><K-spec>_<N><n>INT16</n></N></K-spec></literal-E></E-2></a-stmt>
  <a-stmt><E-1><named-E><N><n>I32</n></N></named-E></E-1>  <a>=</a> <E-2><literal-E><l>2147483647</l><K-spec>_<N><n>INT32</n></N></K-spec></literal-E></E-2></a-stmt>
  <a-stmt><E-1><named-E><N><n>I64</n></N></named-E></E-1>  <a>=</a> <E-2><literal-E><l>9223372036854775807</l><K-spec>_<N><n>INT64</n></N></K-spec></literal-E></E-2></a-stmt>

