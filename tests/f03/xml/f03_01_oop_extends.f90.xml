  <call-stmt>CALL <procedure-designator><named-E><N><n>DESCRIBE</n></N></named-E></procedure-designator>(<arg-spec><arg><named-E><N><n>SP</n></N></named-E></arg></arg-spec>)</call-stmt>

  <C>! Allocation polymorphe</C>
  <allocate-stmt>ALLOCATE(<derived-T-spec><T-N><N><n>CIRCLE</n></N></T-N></derived-T-spec> :: <arg-spec><arg><named-E><N><n>S</n></N></named-E></arg></arg-spec>)</allocate-stmt>
  <select-T-stmt>SELECT TYPE (<selector><named-E><N><n>S</n></N></named-E></selector>)</select-T-stmt>
    <T-is-stmt>TYPE IS <T-selector>(<derived-T-spec><T-N><N><n>CIRCLE</n></N></T-N></derived-T-spec>)</T-selector></T-is-stmt>
      <a-stmt><E-1><named-E><N><n>S</n></N><R-LT><component-R>%<ct>RADIUS</ct></component-R></R-LT></named-E></E-1> <a>=</a> <E-2><literal-E><l>5.0</l></literal-E></E-2></a-stmt>
  <end-select-T-stmt>END SELECT</end-select-T-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>S</n></N><R-LT><component-R>%<ct>AREA</ct></component-R><parens-R>(<element-LT></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>
  <deallocate-stmt>DEALLOCATE(<arg-spec><arg><named-E><N><n>S</n></N></named-E></arg></arg-spec>)</deallocate-stmt>

<end-program-stmt>END PROGRAM <program-N><N><n>OOPTEST</n></N></program-N></end-program-stmt>
