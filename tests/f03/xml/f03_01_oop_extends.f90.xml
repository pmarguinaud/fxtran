  <T-decl-stmt><_T-spec_><derived-T-spec>TYPE(<T-N><N><n>CIRCLE</n></N></T-N>)</derived-T-spec></_T-spec_>    :: <EN-decl-LT><EN-decl><EN-N><N><n>C</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
  <T-decl-stmt><_T-spec_><derived-T-spec>TYPE(<T-N><N><n>RECTANGLE</n></N></T-N>)</derived-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>R</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
  <T-decl-stmt><_T-spec_><derived-T-spec>TYPE(<T-N><N><n>SPHERE</n></N></T-N>)</derived-T-spec></_T-spec_>    :: <EN-decl-LT><EN-decl><EN-N><N><n>SP</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
  <T-decl-stmt><_T-spec_><derived-T-spec>CLASS(<T-N><N><n>SHAPE</n></N></T-N>)</derived-T-spec></_T-spec_>, <attribute><attribute-N>ALLOCATABLE</attribute-N></attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>S</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>

  <a-stmt><E-1><named-E><N><n>C</n></N></named-E></E-1>  <a>=</a> <E-2><named-E><N><n>CIRCLE</n></N><R-LT><parens-R>(<arg-spec><arg><arg-N n="RADIUS"><k>RADIUS</k></arg-N>=<literal-E><l>2.0</l></literal-E></arg></arg-spec>)</parens-R></R-LT></named-E></E-2></a-stmt>
  <a-stmt><E-1><named-E><N><n>R</n></N></named-E></E-1>  <a>=</a> <E-2><named-E><N><n>RECTANGLE</n></N><R-LT><parens-R>(<arg-spec><arg><arg-N n="WIDTH"><k>WIDTH</k></arg-N>=<literal-E><l>3.0</l></literal-E></arg>, <arg><arg-N n="HEIGHT"><k>HEIGHT</k></arg-N>=<literal-E><l>4.0</l></literal-E></arg></arg-spec>)</parens-R></R-LT></named-E></E-2></a-stmt>
  <a-stmt><E-1><named-E><N><n>SP</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>SPHERE</n></N><R-LT><parens-R>(<arg-spec><arg><arg-N n="RADIUS"><k>RADIUS</k></arg-N>=<literal-E><l>1.0</l></literal-E></arg></arg-spec>)</parens-R></R-LT></named-E></E-2></a-stmt>

  <C>! Appels de procedures liees au type</C>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>C</n></N><R-LT><component-R>%<ct>AREA</ct></component-R><parens-R>(<element-LT></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>
