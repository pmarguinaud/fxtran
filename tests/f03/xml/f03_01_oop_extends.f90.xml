<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FREE" source-width="132" openmp="0" openacc="0" openmp-target="0"><file name="f03_01_oop_extends.f90"><C>! Test: heritage de type et polymorphisme</C>
<C>! Statements couverts: TYPE EXTENDS, CLASS, SELECT TYPE / TYPE IS / CLASS IS / END SELECT,</C>
<C>!                      procedures liees au type (type-bound procedures)</C>

<module-stmt>MODULE <module-N><N><n>SHAPESMOD</n></N></module-N></module-stmt>
  <implicit-none-stmt>IMPLICIT NONE</implicit-none-stmt>

  <C>! Type de base</C>
  <T-stmt>TYPE :: <T-N><N><n>SHAPE</n></N></T-N></T-stmt>
    <component-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>COLOR</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><upper-bound><literal-E><l>3</l></literal-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec> = <init-E><array-constructor-E>[<ac-value-LT><ac-value><literal-E><l>0.0</l></literal-E></ac-value>, <ac-value><literal-E><l>0.0</l></literal-E></ac-value>, <ac-value><literal-E><l>0.0</l></literal-E></ac-value></ac-value-LT>]</array-constructor-E></init-E></EN-decl></EN-decl-LT></component-decl-stmt>
  <contains-stmt>CONTAINS</contains-stmt>
    <procedure-stmt>PROCEDURE :: <procedure-N-LT><rename><use-N><n>AREA</n></use-N>  =&gt; <N><n>SHAPE_AREA</n></N></rename></procedure-N-LT></procedure-stmt>
    <procedure-stmt>PROCEDURE :: <procedure-N-LT><rename><use-N><n>PRINT</n></use-N> =&gt; <N><n>SHAPE_PRINT</n></N></rename></procedure-N-LT></procedure-stmt>
  <end-T-stmt>END TYPE <T-N><N><n>SHAPE</n></N></T-N></end-T-stmt>

  <C>! Extension: CIRCLE herite de SHAPE</C>
  <T-stmt>TYPE, <attribute><attribute-N>EXTENDS</attribute-N>(<N><n>SHAPE</n></N>)</attribute> :: <T-N><N><n>CIRCLE</n></N></T-N></T-stmt>
    <component-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>RADIUS</n></N></EN-N></EN-decl></EN-decl-LT></component-decl-stmt>
  <contains-stmt>CONTAINS</contains-stmt>
    <procedure-stmt>PROCEDURE :: <procedure-N-LT><rename><use-N><n>AREA</n></use-N> =&gt; <N><n>CIRCLE_AREA</n></N></rename></procedure-N-LT></procedure-stmt>
  <end-T-stmt>END TYPE <T-N><N><n>CIRCLE</n></N></T-N></end-T-stmt>

  <C>! Extension: RECTANGLE herite de SHAPE</C>
  <T-stmt>TYPE, <attribute><attribute-N>EXTENDS</attribute-N>(<N><n>SHAPE</n></N>)</attribute> :: <T-N><N><n>RECTANGLE</n></N></T-N></T-stmt>
    <component-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>WIDTH</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>HEIGHT</n></N></EN-N></EN-decl></EN-decl-LT></component-decl-stmt>
  <contains-stmt>CONTAINS</contains-stmt>
    <procedure-stmt>PROCEDURE :: <procedure-N-LT><rename><use-N><n>AREA</n></use-N> =&gt; <N><n>RECT_AREA</n></N></rename></procedure-N-LT></procedure-stmt>
  <end-T-stmt>END TYPE <T-N><N><n>RECTANGLE</n></N></T-N></end-T-stmt>

  <C>! Double heritage: SPHERE herite de CIRCLE</C>
  <T-stmt>TYPE, <attribute><attribute-N>EXTENDS</attribute-N>(<N><n>CIRCLE</n></N>)</attribute> :: <T-N><N><n>SPHERE</n></N></T-N></T-stmt>
  <contains-stmt>CONTAINS</contains-stmt>
    <procedure-stmt>PROCEDURE :: <procedure-N-LT><rename><use-N><n>AREA</n></use-N> =&gt; <N><n>SPHERE_AREA</n></N></rename></procedure-N-LT></procedure-stmt>
  <end-T-stmt>END TYPE <T-N><N><n>SPHERE</n></N></T-N></end-T-stmt>

<contains-stmt>CONTAINS</contains-stmt>

  <function-stmt><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec> FUNCTION <function-N><N><n>SHAPE_AREA</n></N></function-N>(<dummy-arg-LT><arg-N><N><n>THIS</n></N></arg-N></dummy-arg-LT>)</function-stmt>
    <T-decl-stmt><_T-spec_><derived-T-spec>CLASS(<T-N><N><n>SHAPE</n></N></T-N>)</derived-T-spec></_T-spec_>, <attribute><attribute-N>INTENT</attribute-N>(<intent-spec>IN</intent-spec>)</attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>THIS</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
    <a-stmt><E-1><named-E><N><n>SHAPE_AREA</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>0.0</l></literal-E></E-2></a-stmt>
  <end-function-stmt>END FUNCTION <function-N><N><n>SHAPE_AREA</n></N></function-N></end-function-stmt>

  <subroutine-stmt>SUBROUTINE <subroutine-N><N><n>SHAPE_PRINT</n></N></subroutine-N>(<dummy-arg-LT><arg-N><N><n>THIS</n></N></arg-N></dummy-arg-LT>)</subroutine-stmt>
    <T-decl-stmt><_T-spec_><derived-T-spec>CLASS(<T-N><N><n>SHAPE</n></N></T-N>)</derived-T-spec></_T-spec_>, <attribute><attribute-N>INTENT</attribute-N>(<intent-spec>IN</intent-spec>)</attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>THIS</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
    <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'SHAPE, AREA ='</S></string-E></output-item>, <output-item><named-E><N><n>THIS</n></N><R-LT><component-R>%<ct>AREA</ct></component-R><parens-R>(<element-LT></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>
  <end-subroutine-stmt>END SUBROUTINE <subroutine-N><N><n>SHAPE_PRINT</n></N></subroutine-N></end-subroutine-stmt>

  <function-stmt><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec> FUNCTION <function-N><N><n>CIRCLE_AREA</n></N></function-N>(<dummy-arg-LT><arg-N><N><n>THIS</n></N></arg-N></dummy-arg-LT>)</function-stmt>
    <T-decl-stmt><_T-spec_><derived-T-spec>CLASS(<T-N><N><n>CIRCLE</n></N></T-N>)</derived-T-spec></_T-spec_>, <attribute><attribute-N>INTENT</attribute-N>(<intent-spec>IN</intent-spec>)</attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>THIS</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
    <a-stmt><E-1><named-E><N><n>CIRCLE_AREA</n></N></named-E></E-1> <a>=</a> <E-2><op-E><literal-E><l>3.14159265</l></literal-E> <op><o>*</o></op> <op-E><named-E><N><n>THIS</n></N><R-LT><component-R>%<ct>RADIUS</ct></component-R></R-LT></named-E><op><o>**</o></op><literal-E><l>2</l></literal-E></op-E></op-E></E-2></a-stmt>
  <end-function-stmt>END FUNCTION <function-N><N><n>CIRCLE_AREA</n></N></function-N></end-function-stmt>

  <function-stmt><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec> FUNCTION <function-N><N><n>RECT_AREA</n></N></function-N>(<dummy-arg-LT><arg-N><N><n>THIS</n></N></arg-N></dummy-arg-LT>)</function-stmt>
    <T-decl-stmt><_T-spec_><derived-T-spec>CLASS(<T-N><N><n>RECTANGLE</n></N></T-N>)</derived-T-spec></_T-spec_>, <attribute><attribute-N>INTENT</attribute-N>(<intent-spec>IN</intent-spec>)</attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>THIS</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
    <a-stmt><E-1><named-E><N><n>RECT_AREA</n></N></named-E></E-1> <a>=</a> <E-2><op-E><named-E><N><n>THIS</n></N><R-LT><component-R>%<ct>WIDTH</ct></component-R></R-LT></named-E> <op><o>*</o></op> <named-E><N><n>THIS</n></N><R-LT><component-R>%<ct>HEIGHT</ct></component-R></R-LT></named-E></op-E></E-2></a-stmt>
  <end-function-stmt>END FUNCTION <function-N><N><n>RECT_AREA</n></N></function-N></end-function-stmt>

  <function-stmt><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec> FUNCTION <function-N><N><n>SPHERE_AREA</n></N></function-N>(<dummy-arg-LT><arg-N><N><n>THIS</n></N></arg-N></dummy-arg-LT>)</function-stmt>
    <T-decl-stmt><_T-spec_><derived-T-spec>CLASS(<T-N><N><n>SPHERE</n></N></T-N>)</derived-T-spec></_T-spec_>, <attribute><attribute-N>INTENT</attribute-N>(<intent-spec>IN</intent-spec>)</attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>THIS</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
    <a-stmt><E-1><named-E><N><n>SPHERE_AREA</n></N></named-E></E-1> <a>=</a> <E-2><op-E><literal-E><l>4.0</l></literal-E> <op><o>*</o></op> <op-E><literal-E><l>3.14159265</l></literal-E> <op><o>*</o></op> <op-E><named-E><N><n>THIS</n></N><R-LT><component-R>%<ct>RADIUS</ct></component-R></R-LT></named-E><op><o>**</o></op><literal-E><l>2</l></literal-E></op-E></op-E></op-E></E-2></a-stmt>
  <end-function-stmt>END FUNCTION <function-N><N><n>SPHERE_AREA</n></N></function-N></end-function-stmt>

  <C>! Procedure polymorphe: prend n'importe quelle SHAPE</C>
  <subroutine-stmt>SUBROUTINE <subroutine-N><N><n>DESCRIBE</n></N></subroutine-N>(<dummy-arg-LT><arg-N><N><n>S</n></N></arg-N></dummy-arg-LT>)</subroutine-stmt>
    <T-decl-stmt><_T-spec_><derived-T-spec>CLASS(<T-N><N><n>SHAPE</n></N></T-N>)</derived-T-spec></_T-spec_>, <attribute><attribute-N>INTENT</attribute-N>(<intent-spec>IN</intent-spec>)</attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>S</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>

    <C>! SELECT TYPE: dispatch selon le type dynamique</C>
    <select-T-stmt>SELECT TYPE (<selector><named-E><N><n>S</n></N></named-E></selector>)</select-T-stmt>
      <T-is-stmt>TYPE IS <T-selector>(<derived-T-spec><T-N><N><n>CIRCLE</n></N></T-N></derived-T-spec>)</T-selector></T-is-stmt>
        <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'CIRCLE, R ='</S></string-E></output-item>, <output-item><named-E><N><n>S</n></N><R-LT><component-R>%<ct>RADIUS</ct></component-R></R-LT></named-E></output-item></output-item-LT></write-stmt>
      <T-is-stmt>TYPE IS <T-selector>(<derived-T-spec><T-N><N><n>RECTANGLE</n></N></T-N></derived-T-spec>)</T-selector></T-is-stmt>
        <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'RECTANGLE'</S></string-E></output-item>, <output-item><named-E><N><n>S</n></N><R-LT><component-R>%<ct>WIDTH</ct></component-R></R-LT></named-E></output-item>, <output-item><string-E><S>'x'</S></string-E></output-item>, <output-item><named-E><N><n>S</n></N><R-LT><component-R>%<ct>HEIGHT</ct></component-R></R-LT></named-E></output-item></output-item-LT></write-stmt>
      <class-is-stmt>CLASS IS <T-selector>(<derived-T-spec><T-N><N><n>SPHERE</n></N></T-N></derived-T-spec>)</T-selector></class-is-stmt>
        <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'SPHERE ou sous-type'</S></string-E></output-item></output-item-LT></write-stmt>
      <class-is-stmt>CLASS <T-selector>DEFAULT</T-selector></class-is-stmt>
        <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'SHAPE generique'</S></string-E></output-item></output-item-LT></write-stmt>
    <end-select-T-stmt>END SELECT</end-select-T-stmt>
  <end-subroutine-stmt>END SUBROUTINE <subroutine-N><N><n>DESCRIBE</n></N></subroutine-N></end-subroutine-stmt>

<end-module-stmt>END MODULE <module-N><N><n>SHAPESMOD</n></N></module-N></end-module-stmt>


<program-stmt>PROGRAM <program-N><N><n>OOPTEST</n></N></program-N></program-stmt>
  <use-stmt>USE <module-N><N><n>SHAPESMOD</n></N></module-N></use-stmt>
