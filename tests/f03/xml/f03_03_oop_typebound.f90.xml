<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FREE" source-width="132" openmp="0" openacc="0" openmp-target="0"><file name="f03_03_oop_typebound.f90"><C>! Test: procedures liees au type avancees</C>
