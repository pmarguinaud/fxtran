    <component-decl-stmt><_T-spec_><procedure-T-spec>PROCEDURE</procedure-T-spec></_T-spec_>, <attribute><attribute-N>NOPASS</attribute-N></attribute>  :: <EN-decl-LT><EN-decl><EN-N><N><n>VERSION</n></N></EN-N> =&gt; <init-E><named-E><N><n>VEC_VERSION</n></N></named-E></init-E></EN-decl></EN-decl-LT></component-decl-stmt>
