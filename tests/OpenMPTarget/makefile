XMLS = $(SOURCES:.f90=.f90.xml)
XMLS := $(XMLS:.f=.f.xml)

all: $(XMLS)

%.f90.xml: %.f90
	$(FXTRAN) $< -no-include -openmp-target -o $@
	@diff xml/$@ $@ || true

%.f.xml: %.f
	$(FXTRAN) $< -no-include -openmp-target -o $@
	@diff xml/$@ $@ || true

clean:
	\rm -f $(XMLS)


