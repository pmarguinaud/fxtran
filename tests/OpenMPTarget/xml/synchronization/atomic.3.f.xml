<m>      </m> <a-stmt><E-1><named-E><N><n>fetch_and_add</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>p</n></N></named-E></E-2></a-stmt>
<m>      </m> <a-stmt><E-1><named-E><N><n>p</n></N></named-E></E-1> <a>=</a> <E-2><op-E><named-E><N><n>p</n></N></named-E> <op><o>+</o></op> <literal-E><l>1</l></literal-E></op-E></E-2></a-stmt>
<omp>!$omp</omp><m> </m><end-atomic-openmp>end atomic</end-atomic-openmp>
