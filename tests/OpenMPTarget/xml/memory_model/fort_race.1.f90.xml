<subroutine-stmt>SUBROUTINE <subroutine-N><N><n>SHARED_RACE</n></N></subroutine-N></subroutine-stmt>

  <include-stmt>INCLUDE <filename><S>&quot;omp_lib.h&quot;</S></filename></include-stmt>      <C>! or USE OMP_LIB</C>

  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec></_T-spec_> <EN-decl-LT><EN-decl><EN-N><N><n>A</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><upper-bound><literal-E><l>20</l></literal-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>INTEGER</T-N></intrinsic-T-spec></_T-spec_> <EN-decl-LT><EN-decl><EN-N><N><n>MYTHREAD</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>

<omp>!$OMP</omp> <parallel-openmp>PARALLEL <clause><N>SHARED</N>(<V-LT><V-N><n>A</n></V-N></V-LT>)</clause> <clause><N>PRIVATE</N>(<V-LT><V-N><n>MYTHREAD</n></V-N></V-LT>)</clause></parallel-openmp>

  <a-stmt><E-1><named-E><N><n>MYTHREAD</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>OMP_GET_THREAD_NUM</n></N><R-LT><parens-R>(<element-LT></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
  <if-then-stmt>IF (<condition-E><op-E><named-E><N><n>MYTHREAD</n></N></named-E> <op><o>.EQ.</o></op> <literal-E><l>0</l></literal-E></op-E></condition-E>) THEN</if-then-stmt>
     <call-stmt>CALL <procedure-designator><named-E><N><n>SUB</n></N></named-E></procedure-designator>(<arg-spec><arg><named-E><N><n>A</n></N><R-LT><array-R>(<section-subscript-LT><section-subscript><lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><literal-E><l>10</l></literal-E></upper-bound></section-subscript></section-subscript-LT>)</array-R></R-LT></named-E></arg></arg-spec>)</call-stmt> <C>! compiler may introduce writes to A(6:10)</C>
  <else-stmt>ELSE</else-stmt>
     <a-stmt><E-1><named-E><N><n>A</n></N><R-LT><array-R>(<section-subscript-LT><section-subscript><lower-bound><literal-E><l>6</l></literal-E></lower-bound>:<upper-bound><literal-E><l>10</l></literal-E></upper-bound></section-subscript></section-subscript-LT>)</array-R></R-LT></named-E></E-1> <a>=</a> <E-2><literal-E><l>12</l></literal-E></E-2></a-stmt>
  <end-if-stmt>ENDIF</end-if-stmt>

<omp>!$OMP</omp> <end-parallel-openmp>END PARALLEL</end-parallel-openmp>

<end-subroutine-stmt>END SUBROUTINE <subroutine-N><N><n>SHARED_RACE</n></N></subroutine-N></end-subroutine-stmt>

<subroutine-stmt>SUBROUTINE <subroutine-N><N><n>SUB</n></N></subroutine-N>(<dummy-arg-LT><arg-N><N><n>X</n></N></arg-N></dummy-arg-LT>)</subroutine-stmt>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec></_T-spec_> <EN-decl-LT><EN-decl><EN-N><N><n>X</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><upper-bound><star-E>*</star-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>
  <a-stmt><E-1><named-E><N><n>X</n></N><R-LT><array-R>(<section-subscript-LT><section-subscript><lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><literal-E><l>5</l></literal-E></upper-bound></section-subscript></section-subscript-LT>)</array-R></R-LT></named-E></E-1> <a>=</a> <E-2><literal-E><l>4</l></literal-E></E-2></a-stmt>
<end-subroutine-stmt>END SUBROUTINE <subroutine-N><N><n>SUB</n></N></subroutine-N></end-subroutine-stmt>
