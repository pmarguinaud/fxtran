<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FREE" source-width="132" openmp="0" openacc="0" openmp-target="1"><file name="memory_model/fort_race.1.f90"><C>! @@name:&#009;fort_race.1</C>
