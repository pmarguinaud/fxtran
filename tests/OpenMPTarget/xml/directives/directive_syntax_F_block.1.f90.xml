<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FREE" source-width="132" openmp="0" openacc="0" openmp-target="1"><file name="directives/directive_syntax_F_block.1.f90"><C>! @@name:&#009;directive_syntax_F_block.1</C>
<C>! @@type:&#009;F-free</C>
<C>! @@operation:&#009;run</C>
<C>! @@expect:&#009;success</C>
<C>! @@version:&#009;omp_5.1</C>
  <program-stmt>program <program-N><N><n>main</n></N></program-N></program-stmt>

     <use-stmt>use <module-N><N><n>omp_lib</n></N></module-N></use-stmt>
     <implicit-none-stmt>implicit none</implicit-none-stmt>
     <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_>,<attribute><attribute-N>parameter</attribute-N></attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>NT</n></N></EN-N> = <init-E><literal-E><l>2</l></literal-E></init-E></EN-decl>, <EN-decl><EN-N><N><n>chunks</n></N></EN-N>=<init-E><literal-E><l>3</l></literal-E></init-E></EN-decl></EN-decl-LT></T-decl-stmt>
    
    <omp>!$omp</omp> <parallel-openmp>parallel <clause><N>num_threads</N>(<named-E><N><n>NT</n></N></named-E>)</clause></parallel-openmp>
     <block-stmt>block</block-stmt>                          <C>! Fortran 2008 OMP 5.1</C>
       <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>thrd_no</n></N></EN-N></EN-decl>,<EN-decl><EN-N><N><n>i</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
       <a-stmt><E-1><named-E><N><n>thrd_no</n></N></named-E></E-1><a>=</a> <E-2><named-E><N><n>omp_get_thread_num</n></N><R-LT><parens-R>(<element-LT></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
        <omp>!$omp</omp> <do-openmp>do <clause><N>schedule</N>(<T>static</T>,<chunk-size><named-E><N><n>chunks</n></N></named-E></chunk-size>)</clause></do-openmp>
        <do-stmt>do <do-V><named-E><N><n>i</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>,<upper-bound><op-E><named-E><N><n>NT</n></N></named-E><op><o>*</o></op><named-E><N><n>chunks</n></N></named-E></op-E></upper-bound></do-stmt>
           <write-stmt>write(<io-control-spec><io-control>*</io-control>,<io-control><string-E><S>'(&quot;ndx=&quot;,i0.2,&quot; thrd_no=&quot;, i0.2)'</S></string-E></io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>i</n></N></named-E></output-item>,<output-item><named-E><N><n>thrd_no</n></N></named-E></output-item></output-item-LT></write-stmt>
        <end-do-stmt>end do</end-do-stmt>
     <end-block-stmt>end block</end-block-stmt>
  <end-program-stmt>end program</end-program-stmt>

<C>! any order</C>
<C>! OUTPUT: ndx=01 thrd_no=00</C>
<C>! OUTPUT: ndx=02 thrd_no=00</C>
<C>! OUTPUT: ndx=03 thrd_no=00</C>
<C>! OUTPUT: ndx=04 thrd_no=01</C>
<C>! OUTPUT: ndx=05 thrd_no=01</C>
<C>! OUTPUT: ndx=06 thrd_no=01</C>
