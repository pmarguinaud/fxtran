<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FREE" source-width="132" openmp="0" openacc="0" openmp-target="1"><file name="program_control/assumption.1.f90"><C>! @@name:       assumption.1</C>
<C>! @@type:       F-free</C>
<C>! @@operation:  compile</C>
<C>! @@expect:     success</C>
<C>! @@version:    omp_5.1</C>

<module-stmt>module <module-N><N><n>m</n></N></module-N></module-stmt>
  <omp>!$omp</omp> <assumes-openmp>assumes <clause><N>no_parallelism</N></clause></assumes-openmp>
  <interface-stmt>interface</interface-stmt>
    <subroutine-stmt>subroutine <subroutine-N><N><n>fun</n></N></subroutine-N>(<dummy-arg-LT><arg-N><N><n>A</n></N></arg-N>, <arg-N><N><n>i</n></N></arg-N></dummy-arg-LT>)</subroutine-stmt>  
      <implicit-none-stmt>implicit none</implicit-none-stmt>       
      <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>A</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><upper-bound><star-E>*</star-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl>,<EN-decl><EN-N><N><n>i</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>   

    <end-subroutine-stmt>end subroutine</end-subroutine-stmt>
  <end-interface-stmt>end interface</end-interface-stmt>

<end-module-stmt>end module</end-module-stmt>

<program-stmt>program <program-N><N><n>main</n></N></program-N></program-stmt>
   <use-stmt>use <module-N><N><n>m</n></N></module-N></use-stmt>
   <implicit-none-stmt>implicit none</implicit-none-stmt>
   <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_>,<attribute><attribute-N>allocatable</attribute-N></attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>A</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec>:</shape-spec></shape-spec-LT>)</array-spec></EN-decl>, <EN-decl><EN-N><N><n>B</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec>:</shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>
   <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_>             :: <EN-decl-LT><EN-decl><EN-N><N><n>i</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>N</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
   <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>real</T-N></intrinsic-T-spec></_T-spec_>                :: <EN-decl-LT><EN-decl><EN-N><N><n>rand_no</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>

   <call-stmt>call <procedure-designator><named-E><N><n>random_number</n></N></named-E></procedure-designator>(<arg-spec><arg><named-E><N><n>rand_no</n></N></named-E></arg></arg-spec>)</call-stmt>   <C>!! create random,</C>
   <a-stmt><E-1><named-E><N><n>N</n></N></named-E></E-1> <a>=</a> <E-2><op-E><parens-E>(<op-E><named-E><N><n>int</n></N><R-LT><parens-R>(<element-LT><element><op-E><named-E><N><n>rand_no</n></N></named-E><op><o>*</o></op><literal-E><l>5</l></literal-E></op-E></element></element-LT>)</parens-R></R-LT></named-E><op><o>+</o></op><literal-E><l>1</l></literal-E></op-E>)</parens-E><op><o>*</o></op><literal-E><l>16</l></literal-E></op-E></E-2></a-stmt>     <C>!! runtime number multiple of 16</C>

   <allocate-stmt>allocate(<arg-spec><arg><named-E><N><n>A</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>N</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></arg>,<arg><named-E><N><n>B</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>N</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></arg></arg-spec>)</allocate-stmt>           <C>!! alloc space &amp; initialize</C>
   <do-stmt>do <do-V><named-E><N><n>i</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>, <upper-bound><named-E><N><n>N</n></N></named-E></upper-bound></do-stmt>
      <a-stmt><E-1><named-E><N><n>A</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>i</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><literal-E><l>0</l></literal-E></E-2></a-stmt><smc>;</smc> <a-stmt><E-1><named-E><N><n>B</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>i</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><named-E><N><n>i</n></N></named-E></E-2></a-stmt> 
   <end-do-stmt>end do</end-do-stmt>

<C>!! Case 1: Delimited scope, see module interface</C>
    
   <omp>!$omp</omp> <target-teams-distribute-parallel-do-openmp>target teams distribute parallel do <clause><N>map</N>(<prefix>tofrom</prefix>: <E-LT><named-E><N><n>A</n></N></named-E></E-LT>)</clause></target-teams-distribute-parallel-do-openmp>
   <do-stmt>do <do-V><named-E><N><n>i</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>, <upper-bound><named-E><N><n>N</n></N></named-E></upper-bound></do-stmt>
     <call-stmt>call <procedure-designator><named-E><N><n>fun</n></N></named-E></procedure-designator>(<arg-spec><arg><named-E><N><n>A</n></N></named-E></arg>,<arg><named-E><N><n>i</n></N></named-E></arg></arg-spec>)</call-stmt>
   <end-do-stmt>end do</end-do-stmt>
    
<C>!! Case 2: Block associated</C>

   <omp>!$omp</omp> <assume-openmp>assume <clause><N>holds</N> (<op-E><op-E><op-E><literal-E><l>8</l></literal-E><op><o>*</o></op><parens-E>(<op-E><named-E><N><n>N</n></N></named-E><op><o>/</o></op><literal-E><l>8</l></literal-E></op-E>)</parens-E></op-E> <op><o>==</o></op> <named-E><N><n>N</n></N></named-E></op-E> <op><o>.and.</o></op> <op-E><named-E><N><n>N</n></N></named-E><op><o>&gt;</o></op><literal-E><l>0</l></literal-E></op-E></op-E>)</clause></assume-openmp>  <C>!! N is multiple of 8</C>
   <omp>!$omp</omp> <simd-openmp>simd</simd-openmp>    
   <do-stmt>do <do-V><named-E><N><n>i</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>, <upper-bound><named-E><N><n>N</n></N></named-E></upper-bound></do-stmt>
     <a-stmt><E-1><named-E><N><n>A</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>i</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><op-E><named-E><N><n>A</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>i</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E> <op><o>+</o></op> <named-E><N><n>B</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>i</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></op-E></E-2></a-stmt>
   <end-do-stmt>end do</end-do-stmt>
   <omp>!$omp</omp> <end-assume-openmp>end assume</end-assume-openmp>

<end-program-stmt>end program</end-program-stmt>
