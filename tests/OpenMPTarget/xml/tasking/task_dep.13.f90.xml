    <omp>!$omp</omp> <task-openmp>task <clause><N>depend</N>(<T><n>inout</n></T>: <E-LT><named-E><N><n>omp_all_memory</n></N></named-E></E-LT>)</clause></task-openmp>   <C>!! Task 4</C>
       <a-stmt><E-1><named-E><N><n>a</n></N></named-E></E-1><a>=</a><E-2><op-E><named-E><N><n>a</n></N></named-E><op><o>+</o></op><literal-E><l>1</l></literal-E></op-E></E-2></a-stmt><smc>;</smc> <a-stmt><E-1><named-E><N><n>d</n></N></named-E></E-1><a>=</a><E-2><op-E><named-E><N><n>d</n></N></named-E><op><o>+</o></op><literal-E><l>1</l></literal-E></op-E></E-2></a-stmt>
