       <write-stmt>write(<io-control-spec><io-control>*</io-control>,<io-control><string-E><S>'(&quot;T6 a=&quot;,i1,&quot; d=&quot;,i1)'</S></string-E></io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>a</n></N></named-E></output-item>, <output-item><named-E><N><n>d</n></N></named-E></output-item></output-item-LT></write-stmt>
