  <omp>!$omp</omp> <end-parallel-masked-openmp>end parallel masked</end-parallel-masked-openmp>

<end-program-stmt>end program</end-program-stmt>

<C>! OUTPUT: ordered  {T2,T3 any order}, {T4}, {T6}</C>
