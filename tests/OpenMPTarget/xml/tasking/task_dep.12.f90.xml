<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FREE" source-width="132" openmp="0" openacc="0" openmp-target="1"><file name="tasking/task_dep.12.f90"><C>! @@name:&#009;task_dep.12</C>
<C>! @@type:&#009;F-free</C>
<C>! @@operation:&#009;run</C>
<C>! @@expect:&#009;success</C>
<C>! @@version:&#009;omp_4.0</C>
<program-stmt>program <program-N><N><n>example</n></N></program-N></program-stmt>
   <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>x</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
   <a-stmt><E-1><named-E><N><n>x</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>0</l></literal-E></E-2></a-stmt>
   <omp>!$omp</omp> <parallel-openmp>parallel</parallel-openmp>
   <omp>!$omp</omp> <single-openmp>single</single-openmp>
     <C>!... first explicit task</C>
      <omp>!$omp</omp> <task-openmp>task <clause><N>shared</N>(<V-LT><V-N><n>x</n></V-N></V-LT>)</clause> <clause><N>depend</N>(<T><n>out</n></T>: <E-LT><named-E><N><n>x</n></N></named-E></E-LT>)</clause></task-openmp>
         <a-stmt><E-1><named-E><N><n>x</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>1</l></literal-E></E-2></a-stmt>
      <omp>!$omp</omp> <end-task-openmp>end task</end-task-openmp>

     <C>!... second explicit task</C>
      <omp>!$omp</omp> <task-openmp>task <clause><N>shared</N>(<V-LT><V-N><n>x</n></V-N></V-LT>)</clause> <clause><N>depend</N>(<T><n>inout</n></T>: <E-LT><named-E><N><n>x</n></N></named-E></E-LT>)</clause> <clause><N>if</N>(<literal-E>.false.</literal-E>)</clause></task-openmp>
         <a-stmt><E-1><named-E><N><n>x</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>2</l></literal-E></E-2></a-stmt>
      <omp>!$omp</omp> <end-task-openmp>end task</end-task-openmp>

     <C>!... statement executed by parent implicit task</C>
     <C>! prints: x = 2</C>
      <print-stmt>print<format>*</format>, <output-item-LT><output-item><string-E><S>&quot;x = &quot;</S></string-E></output-item>, <output-item><named-E><N><n>x</n></N></named-E></output-item></output-item-LT></print-stmt>
   <omp>!$omp</omp> <end-single-openmp>end single</end-single-openmp>
   <omp>!$omp</omp> <end-parallel-openmp>end parallel</end-parallel-openmp>
<end-program-stmt>end program</end-program-stmt>
</file></object>
