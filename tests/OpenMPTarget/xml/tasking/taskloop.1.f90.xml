         <call-stmt>call <procedure-designator><named-E><N><n>loop_body</n></N></named-E></procedure-designator>(<arg-spec><arg><named-E><N><n>i</n></N></named-E></arg>, <arg><named-E><N><n>j</n></N></named-E></arg></arg-spec>)</call-stmt>
      <end-do-stmt>end do</end-do-stmt>
   <end-do-stmt>end do</end-do-stmt>
<omp>!$omp</omp> <end-taskloop-openmp>end taskloop</end-taskloop-openmp>

