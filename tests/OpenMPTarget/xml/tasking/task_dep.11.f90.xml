<subroutine-stmt>subroutine <subroutine-N><N><n>set_an_element</n></N></subroutine-N>(<dummy-arg-LT><arg-N><N><n>e</n></N></arg-N>, <arg-N><N><n>val</n></N></arg-N></dummy-arg-LT>)</subroutine-stmt>
    <implicit-none-stmt>implicit none</implicit-none-stmt>
    <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>e</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>val</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>

    <a-stmt><E-1><named-E><N><n>e</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>val</n></N></named-E></E-2></a-stmt>

<end-subroutine-stmt>end subroutine</end-subroutine-stmt> 

<subroutine-stmt>subroutine <subroutine-N><N><n>print_all_elements</n></N></subroutine-N>(<dummy-arg-LT><arg-N><N><n>v</n></N></arg-N>, <arg-N><N><n>n</n></N></arg-N></dummy-arg-LT>)</subroutine-stmt>
    <implicit-none-stmt>implicit none</implicit-none-stmt>
    <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>n</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>v</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><upper-bound><named-E><N><n>n</n></N></named-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>

    <print-stmt>print <format>*</format>, <output-item-LT><output-item><named-E><N><n>v</n></N></named-E></output-item></output-item-LT></print-stmt>

<end-subroutine-stmt>end subroutine</end-subroutine-stmt> 

<subroutine-stmt>subroutine <subroutine-N><N><n>parallel_computation</n></N></subroutine-N>(<dummy-arg-LT><arg-N><N><n>n</n></N></arg-N></dummy-arg-LT>)</subroutine-stmt>
    <implicit-none-stmt>implicit none</implicit-none-stmt>
    <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>n</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
    <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>i</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>v</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><upper-bound><named-E><N><n>n</n></N></named-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>
  
    <omp>!$omp</omp> <parallel-openmp>parallel</parallel-openmp>
    <omp>!$omp</omp> <single-openmp>single</single-openmp>
        <do-stmt>do <do-V><named-E><N><n>i</n></N></named-E></do-V>=<lower-bound><literal-E><l>1</l></literal-E></lower-bound>, <upper-bound><named-E><N><n>n</n></N></named-E></upper-bound></do-stmt>
            <omp>!$omp</omp> <task-openmp>task <clause><N>depend</N>(<T><n>out</n></T>: <E-LT><named-E><N><n>v</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>i</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-LT>)</clause></task-openmp>
                 <call-stmt>call <procedure-designator><named-E><N><n>set_an_element</n></N></named-E></procedure-designator>(<arg-spec><arg><named-E><N><n>v</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>i</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></arg>, <arg><named-E><N><n>i</n></N></named-E></arg></arg-spec>)</call-stmt>
            <omp>!$omp</omp> <end-task-openmp>end task</end-task-openmp>
        <end-do-stmt>enddo</end-do-stmt>

        <omp>!$omp</omp> <task-openmp>task <clause><N>depend</N>(<depend-modifier>iterator(it = 1:n)</depend-modifier>, <T><n>in</n></T>: <E-LT><named-E><N><n>v</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>it</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-LT>)</clause></task-openmp>
       <C>!!$omp task depend(in: v(1:n)) Violates Array section restriction.</C>
            <call-stmt>call <procedure-designator><named-E><N><n>print_all_elements</n></N></named-E></procedure-designator>(<arg-spec><arg><named-E><N><n>v</n></N></named-E></arg>, <arg><named-E><N><n>n</n></N></named-E></arg></arg-spec>)</call-stmt>
        <omp>!$omp</omp> <end-task-openmp>end task</end-task-openmp>

    <omp>!$omp</omp> <end-single-openmp>end single</end-single-openmp>
    <omp>!$omp</omp> <end-parallel-openmp>end parallel</end-parallel-openmp>
<end-subroutine-stmt>end subroutine</end-subroutine-stmt>
