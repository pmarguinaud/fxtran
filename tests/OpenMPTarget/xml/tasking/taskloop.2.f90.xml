<subroutine-stmt>subroutine <subroutine-N><N><n>parallel_work</n></N></subroutine-N></subroutine-stmt>
    <implicit-none-stmt>implicit none</implicit-none-stmt>
    <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>x1</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>x2</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
    <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>i</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
    <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>parameter</attribute-N></attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>T</n></N></EN-N> = <init-E><literal-E><l>16</l></literal-E></init-E></EN-decl></EN-decl-LT></T-decl-stmt>
    <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>parameter</attribute-N></attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>N</n></N></EN-N> = <init-E><literal-E><l>1024</l></literal-E></init-E></EN-decl></EN-decl-LT></T-decl-stmt>

    <a-stmt><E-1><named-E><N><n>x1</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>0</l></literal-E></E-2></a-stmt>
    <a-stmt><E-1><named-E><N><n>x2</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>0</l></literal-E></E-2></a-stmt>
    <omp>!$omp</omp> <parallel-openmp>parallel <clause><N>shared</N>(<V-LT><V-N><n>x1</n></V-N>,<V-N><n>x2</n></V-N></V-LT>)</clause> <clause><N>num_threads</N>(<named-E><N><n>T</n></N></named-E>)</clause></parallel-openmp>
    <omp>!$omp</omp> <taskloop-openmp>taskloop</taskloop-openmp>
    <do-stmt>do <do-V><named-E><N><n>i</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>,<upper-bound><named-E><N><n>N</n></N></named-E></upper-bound></do-stmt>
        <omp>!$omp</omp> <atomic-openmp>atomic</atomic-openmp>
        <a-stmt><E-1><named-E><N><n>x1</n></N></named-E></E-1> <a>=</a> <E-2><op-E><named-E><N><n>x1</n></N></named-E> <op><o>+</o></op> <literal-E><l>1</l></literal-E></op-E></E-2></a-stmt>     <C>! executed T*N times</C>
        <omp>!$omp</omp> <end-atomic-openmp>end atomic</end-atomic-openmp>
    <end-do-stmt>end do</end-do-stmt>
    <omp>!$omp</omp> <end-taskloop-openmp>end taskloop</end-taskloop-openmp>

    <omp>!$omp</omp> <single-openmp>single</single-openmp>
    <omp>!$omp</omp> <taskloop-openmp>taskloop</taskloop-openmp>
    <do-stmt>do <do-V><named-E><N><n>i</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>,<upper-bound><named-E><N><n>N</n></N></named-E></upper-bound></do-stmt>
        <omp>!$omp</omp> <atomic-openmp>atomic</atomic-openmp>
        <a-stmt><E-1><named-E><N><n>x2</n></N></named-E></E-1> <a>=</a> <E-2><op-E><named-E><N><n>x2</n></N></named-E> <op><o>+</o></op> <literal-E><l>1</l></literal-E></op-E></E-2></a-stmt>     <C>! executed N times</C>
        <omp>!$omp</omp> <end-atomic-openmp>end atomic</end-atomic-openmp>
    <end-do-stmt>end do</end-do-stmt>
    <omp>!$omp</omp> <end-taskloop-openmp>end taskloop</end-taskloop-openmp>
    <omp>!$omp</omp> <end-single-openmp>end single</end-single-openmp>
    <omp>!$omp</omp> <end-parallel-openmp>end parallel</end-parallel-openmp>

    <write-stmt>write (<io-control-spec><io-control>*</io-control>,<io-control><string-E><S>'(A,I0,A,I0)'</S></string-E></io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'x1 = '</S></string-E></output-item>, <output-item><named-E><N><n>x1</n></N></named-E></output-item>, <output-item><string-E><S>', x2 = '</S></string-E></output-item>,<output-item><named-E><N><n>x2</n></N></named-E></output-item></output-item-LT></write-stmt>
<end-subroutine-stmt>end subroutine</end-subroutine-stmt>
