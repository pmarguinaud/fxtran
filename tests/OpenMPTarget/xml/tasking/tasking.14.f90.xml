<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FREE" source-width="132" openmp="0" openacc="0" openmp-target="1"><file name="tasking/tasking.14.f90"><C>! @@name:&#009;tasking.14</C>
<C>! @@type:&#009;F-free</C>
<C>! @@operation:&#009;compile</C>
<C>! @@expect:&#009;success</C>
<C>! @@version:&#009;omp_3.1</C>
<subroutine-stmt>subroutine <subroutine-N><N><n>foo</n></N></subroutine-N>(<dummy-arg-LT></dummy-arg-LT>)</subroutine-stmt>
<T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_> <EN-decl-LT><EN-decl><EN-N><N><n>i</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
<omp>!$omp</omp> <task-openmp>task <clause><N>if</N>(<literal-E>.FALSE.</literal-E>)</clause></task-openmp> <C>! This task is undeferred</C>
<omp>!$omp</omp> <task-openmp>task</task-openmp>             <C>! This task is a regular task</C>
  <do-stmt>do <do-V><named-E><N><n>i</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>, <upper-bound><literal-E><l>3</l></literal-E></upper-bound></do-stmt>
    <omp>!$omp</omp> <task-openmp>task</task-openmp>             <C>! This task is a regular task</C>
      <call-stmt>call <procedure-designator><named-E><N><n>bar</n></N></named-E></procedure-designator>(<arg-spec></arg-spec>)</call-stmt>
    <omp>!$omp</omp> <end-task-openmp>end task</end-task-openmp>
  <end-do-stmt>enddo</end-do-stmt>
<omp>!$omp</omp> <end-task-openmp>end task</end-task-openmp>
<omp>!$omp</omp> <end-task-openmp>end task</end-task-openmp>
<omp>!$omp</omp> <task-openmp>task <clause><N>final</N>(<literal-E>.TRUE.</literal-E>)</clause></task-openmp> <C>! This task is a regular task</C>
<omp>!$omp</omp> <task-openmp>task</task-openmp>               <C>! This task is included</C>
  <do-stmt>do <do-V><named-E><N><n>i</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>, <upper-bound><literal-E><l>3</l></literal-E></upper-bound></do-stmt>
    <omp>!$omp</omp> <task-openmp>task</task-openmp>               <C>! This task is also included</C>
     <call-stmt>call <procedure-designator><named-E><N><n>bar</n></N></named-E></procedure-designator>(<arg-spec></arg-spec>)</call-stmt>
    <omp>!$omp</omp> <end-task-openmp>end task</end-task-openmp>
  <end-do-stmt>enddo</end-do-stmt>
<omp>!$omp</omp> <end-task-openmp>end task</end-task-openmp>
<omp>!$omp</omp> <end-task-openmp>end task</end-task-openmp>
<end-subroutine-stmt>end subroutine</end-subroutine-stmt>
