<m>      </m><common-stmt>COMMON/<common-block-N><n>BLOCKX</n></common-block-N>/<common-block-obj-LT><common-block-obj><common-block-obj-N><N><n>X</n></N></common-block-obj-N></common-block-obj></common-block-obj-LT></common-stmt>
<m>      </m><common-stmt>COMMON/<common-block-N><n>BLOCKY</n></common-block-N>/<common-block-obj-LT><common-block-obj><common-block-obj-N><N><n>Y</n></N></common-block-obj-N></common-block-obj></common-block-obj-LT></common-stmt>
<m>      </m><common-stmt>COMMON/<common-block-N><n>BLOCKZ</n></common-block-N>/<common-block-obj-LT><common-block-obj><common-block-obj-N><N><n>Z</n></N></common-block-obj-N></common-block-obj></common-block-obj-LT></common-stmt>
<omp>!$OMP</omp><m> </m><threadprivate-openmp>THREADPRIVATE(<V-LT><common-block>/<common-block-N><n>BLOCKX</n></common-block-N>/</common-block></V-LT>)</threadprivate-openmp>

<m>      </m>  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>INTEGER</T-N></intrinsic-T-spec></_T-spec_> <EN-decl-LT><EN-decl><EN-N><N><n>I</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>J</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
<m>      </m>  <a-stmt><E-1><named-E><N><n>i</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>1</l></literal-E></E-2></a-stmt>

<omp>!$OMP</omp><m> </m>  <parallel-openmp>PARALLEL <clause><N>DEFAULT</N>(<T>NONE</T>)</clause> <clause><N>PRIVATE</N>(<V-LT><V-N><n>A</n></V-N></V-LT>)</clause> <clause><N>SHARED</N>(<V-LT><V-N><n>Z</n></V-N></V-LT>)</clause> <clause><N>PRIVATE</N>(<V-LT><V-N><n>J</n></V-N></V-LT>)</clause></parallel-openmp>
<m>      </m>    <a-stmt><E-1><named-E><N><n>J</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>OMP_GET_NUM_THREADS</n></N><R-LT><parens-R>(<element-LT></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt><smc>;</smc>
<m>      </m>             <C>! O.K.  - J is listed in PRIVATE clause</C>
