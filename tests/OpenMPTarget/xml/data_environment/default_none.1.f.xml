<m>      </m>    <a-stmt><E-1><named-E><N><n>Z</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><named-E><N><n>Y</n></N></named-E></E-2></a-stmt> <C>! Error - cannot reference I or Y here</C>

<omp>!$OMP</omp><m> </m><do-openmp>DO <clause><N>firstprivate</N>(<V-LT><V-N><n>y</n></V-N></V-LT>)</clause></do-openmp>
<m>    </m><C>! Error - Cannot reference y in the firstprivate clause</C>
<m>      </m>    <do-stmt>DO <do-V><named-E><N><n>I</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>,<upper-bound><literal-E><l>10</l></literal-E></upper-bound></do-stmt>
<m>      </m>       <a-stmt><E-1><named-E><N><n>Z</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><named-E><N><n>I</n></N></named-E></E-2></a-stmt> <C>! O.K. - I is the loop iteration variable</C>
<m>      </m>    <end-do-stmt>END DO</end-do-stmt>


<m>      </m>    <a-stmt><E-1><named-E><N><n>Z</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><named-E><N><n>Y</n></N></named-E></E-2></a-stmt>    <C>! Error - cannot reference I or Y here</C>
