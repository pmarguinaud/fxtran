<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FREE" source-width="132" openmp="0" openacc="0" openmp-target="1"><file name="data_environment/task_reduction.2.f90"><C>! @@name:&#009;task_reduction.2</C>
<C>! @@type:&#009;F-free</C>
<C>! @@operation:&#009;run</C>
<C>! @@expect:&#009;success</C>
<C>! @@version:&#009;omp_5.0</C>
<program-stmt>program <program-N><N><n>task_modifier</n></N></program-N></program-stmt>

   <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>N</n></N></EN-N>=<init-E><literal-E><l>100</l></literal-E></init-E></EN-decl>, <EN-decl><EN-N><N><n>M</n></N></EN-N>=<init-E><literal-E><l>10</l></literal-E></init-E></EN-decl></EN-decl-LT></T-decl-stmt>
   <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>i</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>x</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>

<C>! USE CASE 1  explicit-task reduction + parallel reduction clause</C>
   <a-stmt><E-1><named-E><N><n>x</n></N></named-E></E-1><a>=</a><E-2><literal-E><l>0</l></literal-E></E-2></a-stmt> 
   <omp>!$omp</omp> <parallel-openmp>parallel <clause><N>num_threads</N>(<named-E><N><n>M</n></N></named-E>)</clause> <clause><N>reduction</N>(<modifier-N><n>task</n></modifier-N>,<op><o>+</o></op>:<V-LT><V><n>x</n></V></V-LT>)</clause></parallel-openmp> 

     <a-stmt><E-1><named-E><N><n>x</n></N></named-E></E-1><a>=</a><E-2><op-E><named-E><N><n>x</n></N></named-E><op><o>+</o></op><literal-E><l>1</l></literal-E></op-E></E-2></a-stmt>                   <C>!! implicit task reduction statement</C>

     <omp>!$omp</omp> <single-openmp>single</single-openmp>
       <do-stmt>do <do-V><named-E><N><n>i</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>,<upper-bound><named-E><N><n>N</n></N></named-E></upper-bound></do-stmt>
         <omp>!$omp</omp> <task-openmp>task <clause><N>in_reduction</N>(<op><o>+</o></op>:<V-LT><V><n>x</n></V></V-LT>)</clause></task-openmp>
           <a-stmt><E-1><named-E><N><n>x</n></N></named-E></E-1><a>=</a><E-2><op-E><named-E><N><n>x</n></N></named-E><op><o>+</o></op><literal-E><l>1</l></literal-E></op-E></E-2></a-stmt>
         <omp>!$omp</omp> <end-task-openmp>end task</end-task-openmp>
       <end-do-stmt>end do</end-do-stmt>
     <omp>!$omp</omp> <end-single-openmp>end single</end-single-openmp>
   
   <omp>!$omp</omp> <end-parallel-openmp>end parallel</end-parallel-openmp>
   <write-stmt>write(<io-control-spec><io-control>*</io-control>,<io-control><string-E><S>'(&quot;x=&quot;,I0,&quot; =M+N&quot;)'</S></string-E></io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>x</n></N></named-E></output-item></output-item-LT></write-stmt>   <C>! x= 110 =M+N</C>


<C>! USE CASE 2  task reduction +  worksharing reduction clause</C>
   <a-stmt><E-1><named-E><N><n>x</n></N></named-E></E-1><a>=</a><E-2><literal-E><l>0</l></literal-E></E-2></a-stmt>
   <omp>!$omp</omp> <parallel-openmp>parallel <clause><N>do</N></clause> <clause><N>num_threads</N>(<named-E><N><n>M</n></N></named-E>)</clause> <clause><N>reduction</N>(<modifier-N><n>task</n></modifier-N>,<op><o>+</o></op>:<V-LT><V><n>x</n></V></V-LT>)</clause></parallel-openmp>
     <do-stmt>do <do-V><named-E><N><n>i</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>,<upper-bound><named-E><N><n>N</n></N></named-E></upper-bound></do-stmt>
  
        <a-stmt><E-1><named-E><N><n>x</n></N></named-E></E-1><a>=</a><E-2><op-E><named-E><N><n>x</n></N></named-E><op><o>+</o></op><literal-E><l>1</l></literal-E></op-E></E-2></a-stmt>
  
        <if-then-stmt>if( <condition-E><op-E><named-E><N><n>mod</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>i</n></N></named-E></element>,<element><literal-E><l>2</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E> <op><o>==</o></op> <literal-E><l>0</l></literal-E></op-E></condition-E>) then</if-then-stmt>
           <omp>!$omp</omp> <task-openmp>task <clause><N>in_reduction</N>(<op><o>+</o></op>:<V-LT><V><n>x</n></V></V-LT>)</clause></task-openmp>
             <a-stmt><E-1><named-E><N><n>x</n></N></named-E></E-1><a>=</a><E-2><op-E><named-E><N><n>x</n></N></named-E><op><o>-</o></op><literal-E><l>1</l></literal-E></op-E></E-2></a-stmt>
           <omp>!$omp</omp> <end-task-openmp>end task</end-task-openmp>
        <end-if-stmt>endif</end-if-stmt>
  
     <end-do-stmt>end do</end-do-stmt>
   <write-stmt>write(<io-control-spec><io-control>*</io-control>,<io-control><string-E><S>'(&quot;x=&quot;,I0,&quot;  =N-N/2&quot;)'</S></string-E></io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>x</n></N></named-E></output-item></output-item-LT></write-stmt>   <C>! x= 50 =N-N/2</C>

<end-program-stmt>end program</end-program-stmt>
</file></object>
