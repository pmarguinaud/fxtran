<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FIXED" source-width="72" openmp="0" openacc="0" openmp-target="1"><file name="data_environment/fort_sa_private.5.f"><C>! @@name:fort_sa_private.5</C>
<C>! @@type:F-fixed</C>
<C>! @@operation:run</C>
<C>! @@expect:unspecified</C>
<C>! @@version:omp_5.1</C>
<m>      </m><subroutine-stmt>SUBROUTINE <subroutine-N><N><n>SUB1</n></N></subroutine-N>(<dummy-arg-LT><arg-N><N><n>X</n></N></arg-N></dummy-arg-LT>)</subroutine-stmt>
<m>      </m>  <DIM-stmt>DIMENSION <EN-decl-LT><EN-decl><EN-N><N><n>X</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><upper-bound><star-E>*</star-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></DIM-stmt>

<m>      </m>  <C>! This use of X does not conform to the</C>
<m>      </m>  <C>! specification. It would be legal Fortran 90,</C>
<m>      </m>  <C>! but the OpenMP private directive allows the</C>
<m>      </m>  <C>! compiler to break the sequence association that</C>
<m>      </m>  <C>! A had with the rest of the common block.</C>

<m>      </m>  <forall-stmt>FORALL (<forall-triplet-spec-LT><forall-triplet-spec><V><named-E><N><n>I</n></N></named-E></V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><literal-E><l>10</l></literal-E></upper-bound></forall-triplet-spec></forall-triplet-spec-LT>) <action-stmt><a-stmt><E-1><named-E><N><n>X</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><named-E><N><n>I</n></N></named-E></E-2></a-stmt></action-stmt></forall-stmt>
<m>      </m><end-subroutine-stmt>END SUBROUTINE <subroutine-N><N><n>SUB1</n></N></subroutine-N></end-subroutine-stmt>

<m>      </m><program-stmt>PROGRAM <program-N><N><n>PRIV_RESTRICT5</n></N></program-N></program-stmt>
<m>      </m>  <common-stmt>COMMON /<common-block-N><n>BLOCK5</n></common-block-N>/ <common-block-obj-LT><common-block-obj><common-block-obj-N><N><n>A</n></N></common-block-obj-N></common-block-obj></common-block-obj-LT></common-stmt>

<m>      </m>  <DIM-stmt>DIMENSION <EN-decl-LT><EN-decl><EN-N><N><n>A</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><upper-bound><literal-E><l>1</l></literal-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl>,<EN-decl><EN-N><N><n>B</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><upper-bound><literal-E><l>10</l></literal-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></DIM-stmt>
<m>      </m>  <equivalence-stmt>EQUIVALENCE <equivalence-set-LT><equivalence-set>(<equivalence-obj-LT><equivalence-obj><named-E><N><n>A</n></N></named-E></equivalence-obj>,<equivalence-obj><named-E><N><n>B</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>1</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></equivalence-obj></equivalence-obj-LT>)</equivalence-set></equivalence-set-LT></equivalence-stmt>

<m>      </m>  <C>! the common block has to be at least 10 words</C>
<m>      </m>  <a-stmt><E-1><named-E><N><n>A</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>0</l></literal-E></E-2></a-stmt>

<omp>!$OMP</omp><m> </m>  <parallel-openmp>PARALLEL <clause><N>PRIVATE</N>(<V-LT><common-block>/<common-block-N><n>BLOCK5</n></common-block-N>/</common-block></V-LT>)</clause></parallel-openmp>

<m>      </m>    <C>! Without the private clause,</C>
<m>      </m>    <C>! we would be passing a member of a sequence</C>
<m>      </m>    <C>! that is at least ten elements long.</C>
<m>      </m>    <C>! With the private clause, A may no longer be</C>
<m>      </m>    <C>! sequence-associated.</C>

<m>      </m>    <call-stmt>CALL <procedure-designator><named-E><N><n>SUB1</n></N></named-E></procedure-designator>(<arg-spec><arg><named-E><N><n>A</n></N></named-E></arg></arg-spec>)</call-stmt>
<omp>!$OMP</omp><m> </m>    <masked-openmp>MASKED</masked-openmp>
<m>      </m>      <print-stmt>PRINT <format>*</format>, <output-item-LT><output-item><named-E><N><n>A</n></N></named-E></output-item></output-item-LT></print-stmt>
<omp>!$OMP</omp><m> </m>    <end-masked-openmp>END MASKED</end-masked-openmp>

<omp>!$OMP</omp><m> </m>  <end-parallel-openmp>END PARALLEL</end-parallel-openmp>
<m>      </m><end-program-stmt>END PROGRAM <program-N><N><n>PRIV_RESTRICT5</n></N></program-N></end-program-stmt>
</file></object>
