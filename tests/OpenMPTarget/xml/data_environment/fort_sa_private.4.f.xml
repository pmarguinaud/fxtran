<m>      </m>  <equivalence-stmt>EQUIVALENCE <equivalence-set-LT><equivalence-set>(<equivalence-obj-LT><equivalence-obj><named-E><N><n>A</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>51</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></equivalence-obj>, <equivalence-obj><named-E><N><n>B</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>1</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></equivalence-obj></equivalence-obj-LT>)</equivalence-set></equivalence-set-LT></equivalence-stmt>

<omp>!$OMP</omp><m> </m><parallel-openmp>PARALLEL <clause><N>DO</N></clause> <clause><N>DEFAULT</N>(<T>PRIVATE</T>)</clause> <clause><N>PRIVATE</N>(<V-LT><V-N><n>I</n></V-N>,<V-N><n>J</n></V-N></V-LT>)</clause> <clause><N>LASTPRIVATE</N>(<named-E><N><n>A</n></N></named-E>)</clause></parallel-openmp>
<m>      </m>    <do-stmt>DO <do-V><named-E><N><n>I</n></N></named-E></do-V>=<lower-bound><literal-E><l>1</l></literal-E></lower-bound>,<upper-bound><literal-E><l>100</l></literal-E></upper-bound></do-stmt>
<m>      </m>       <do-stmt>DO <do-V><named-E><N><n>J</n></N></named-E></do-V>=<lower-bound><literal-E><l>1</l></literal-E></lower-bound>,<upper-bound><literal-E><l>100</l></literal-E></upper-bound></do-stmt>
<m>      </m>         <a-stmt><E-1><named-E><N><n>B</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>J</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><op-E><named-E><N><n>J</n></N></named-E> <op><o>-</o></op> <literal-E><l>1</l></literal-E></op-E></E-2></a-stmt>
