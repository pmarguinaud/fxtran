<m>      </m>       <end-do-stmt>ENDDO</end-do-stmt>

<m>      </m>       <do-stmt>DO <do-V><named-E><N><n>J</n></N></named-E></do-V>=<lower-bound><literal-E><l>1</l></literal-E></lower-bound>,<upper-bound><literal-E><l>50</l></literal-E></upper-bound></do-stmt>
<m>      </m>         <a-stmt><E-1><named-E><N><n>B</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>J</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><op-E><named-E><N><n>B</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>J</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E> <op><o>+</o></op> <literal-E><l>1</l></literal-E></op-E></E-2></a-stmt>  <C>! B is undefined</C>
