<C>! @@expect:&#009;success</C>
<C>! @@version:&#009;omp_5.2</C>
<module-stmt>module <module-N><N><n>m</n></N></module-N></module-stmt>
   <interface-stmt>interface</interface-stmt>
      <subroutine-stmt>subroutine <subroutine-N><N><n>do_work</n></N></subroutine-N>(<dummy-arg-LT><arg-N><N><n>a</n></N></arg-N>, <arg-N><N><n>nx</n></N></arg-N>, <arg-N><N><n>ny</n></N></arg-N></dummy-arg-LT>)</subroutine-stmt>
         <omp>!$omp</omp> <declare-target-openmp>declare target enter(do_work)</declare-target-openmp>
         <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>intent</attribute-N>(<intent-spec>in</intent-spec>)</attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>nx</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>ny</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
         <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>double precision</T-N></intrinsic-T-spec></_T-spec_> <EN-decl-LT><EN-decl><EN-N><N><n>a</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><lower-bound><literal-E><l>0</l></literal-E></lower-bound>:<upper-bound><op-E><named-E><N><n>nx</n></N></named-E><op><o>+</o></op><literal-E><l>1</l></literal-E></op-E></upper-bound></shape-spec>,<shape-spec><upper-bound><named-E><N><n>ny</n></N></named-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>
      <end-subroutine-stmt>end subroutine <subroutine-N><N><n>do_work</n></N></subroutine-N></end-subroutine-stmt>

      <subroutine-stmt>subroutine <subroutine-N><N><n>other_work</n></N></subroutine-N>(<dummy-arg-LT><arg-N><N><n>a</n></N></arg-N>, <arg-N><N><n>nx</n></N></arg-N>, <arg-N><N><n>ny</n></N></arg-N></dummy-arg-LT>)</subroutine-stmt>
         <omp>!$omp</omp> <declare-target-openmp>declare target enter(other_work)</declare-target-openmp>
         <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>intent</attribute-N>(<intent-spec>in</intent-spec>)</attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>nx</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>ny</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
         <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>double precision</T-N></intrinsic-T-spec></_T-spec_> <EN-decl-LT><EN-decl><EN-N><N><n>a</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><lower-bound><literal-E><l>0</l></literal-E></lower-bound>:<upper-bound><op-E><named-E><N><n>nx</n></N></named-E><op><o>+</o></op><literal-E><l>1</l></literal-E></op-E></upper-bound></shape-spec>,<shape-spec><upper-bound><named-E><N><n>ny</n></N></named-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>
      <end-subroutine-stmt>end subroutine <subroutine-N><N><n>other_work</n></N></subroutine-N></end-subroutine-stmt>

      <subroutine-stmt>subroutine <subroutine-N><N><n>exch_data</n></N></subroutine-N>(<dummy-arg-LT><arg-N><N><n>a</n></N></arg-N>, <arg-N><N><n>nx</n></N></arg-N>, <arg-N><N><n>ny</n></N></arg-N></dummy-arg-LT>)</subroutine-stmt>
         <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>intent</attribute-N>(<intent-spec>in</intent-spec>)</attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>nx</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>ny</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
         <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>double precision</T-N></intrinsic-T-spec></_T-spec_> <EN-decl-LT><EN-decl><EN-N><N><n>a</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><lower-bound><literal-E><l>0</l></literal-E></lower-bound>:<upper-bound><op-E><named-E><N><n>nx</n></N></named-E><op><o>+</o></op><literal-E><l>1</l></literal-E></op-E></upper-bound></shape-spec>,<shape-spec><upper-bound><named-E><N><n>ny</n></N></named-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>
      <end-subroutine-stmt>end subroutine <subroutine-N><N><n>exch_data</n></N></subroutine-N></end-subroutine-stmt>
   <end-interface-stmt>end interface</end-interface-stmt>
<end-module-stmt>end module <module-N><N><n>m</n></N></module-N></end-module-stmt>

<subroutine-stmt>subroutine <subroutine-N><N><n>array_shaping</n></N></subroutine-N>(<dummy-arg-LT><arg-N><N><n>a</n></N></arg-N>, <arg-N><N><n>nx</n></N></arg-N>, <arg-N><N><n>ny</n></N></arg-N></dummy-arg-LT>)</subroutine-stmt>
   <use-stmt>use <module-N><N><n>m</n></N></module-N></use-stmt>
   <implicit-none-stmt>implicit none</implicit-none-stmt>
   <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>intent</attribute-N>(<intent-spec>in</intent-spec>)</attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>nx</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>ny</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
   <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>double precision</T-N></intrinsic-T-spec></_T-spec_> <EN-decl-LT><EN-decl><EN-N><N><n>a</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><lower-bound><literal-E><l>0</l></literal-E></lower-bound>:<upper-bound><op-E><named-E><N><n>nx</n></N></named-E><op><o>+</o></op><literal-E><l>1</l></literal-E></op-E></upper-bound></shape-spec>,<shape-spec><upper-bound><named-E><N><n>ny</n></N></named-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>

   <C>! map data to device and do work</C>
   <omp>!$omp</omp> <target-data-openmp>target data <clause><N>map</N>(<E-LT><named-E><N><n>a</n></N></named-E></E-LT>)</clause></target-data-openmp>

      <C>! do work on the device</C>
      <omp>!$omp</omp> <target-openmp>target</target-openmp>      <C>! map(a) is optional here</C>
      <call-stmt>call <procedure-designator><named-E><N><n>do_work</n></N></named-E></procedure-designator>(<arg-spec><arg><named-E><N><n>a</n></N></named-E></arg>, <arg><named-E><N><n>nx</n></N></named-E></arg>, <arg><named-E><N><n>ny</n></N></named-E></arg></arg-spec>)</call-stmt>
      <omp>!$omp</omp> <end-target-openmp>end target</end-target-openmp>

      <C>! update boundary points (two rows of 2D array) on the host.</C>
      <C>! data transferred are noncontiguous</C>
      <omp>!$omp</omp> <target-update-openmp>target update <clause><N>from</N>( <E-LT><named-E><N><n>a</n></N><R-LT><array-R>(<section-subscript-LT><section-subscript><lower-bound><literal-E><l>1</l></literal-E></lower-bound></section-subscript>,<section-subscript><lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><named-E><N><n>ny</n></N></named-E></upper-bound></section-subscript></section-subscript-LT>)</array-R></R-LT></named-E>, <named-E><N><n>a</n></N><R-LT><array-R>(<section-subscript-LT><section-subscript><lower-bound><named-E><N><n>nx</n></N></named-E></lower-bound></section-subscript>,<section-subscript><lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><named-E><N><n>ny</n></N></named-E></upper-bound></section-subscript></section-subscript-LT>)</array-R></R-LT></named-E> )</E-LT></clause></target-update-openmp>

      <C>! exchange ghost points with neighbors</C>
      <call-stmt>call <procedure-designator><named-E><N><n>exch_data</n></N></named-E></procedure-designator>(<arg-spec><arg><named-E><N><n>a</n></N></named-E></arg>, <arg><named-E><N><n>nx</n></N></named-E></arg>, <arg><named-E><N><n>ny</n></N></named-E></arg></arg-spec>)</call-stmt>

      <C>! update ghost points (two rows of 2D array) on the device.</C>
      <C>! data transferred are noncontiguous</C>
      <omp>!$omp</omp> <target-update-openmp>target update <clause><N>to</N>( <E-LT><named-E><N><n>a</n></N><R-LT><array-R>(<section-subscript-LT><section-subscript><lower-bound><literal-E><l>0</l></literal-E></lower-bound></section-subscript>,<section-subscript><lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><named-E><N><n>ny</n></N></named-E></upper-bound></section-subscript></section-subscript-LT>)</array-R></R-LT></named-E>, <named-E><N><n>a</n></N><R-LT><array-R>(<section-subscript-LT><section-subscript><lower-bound><op-E><named-E><N><n>nx</n></N></named-E><op><o>+</o></op><literal-E><l>1</l></literal-E></op-E></lower-bound></section-subscript>,<section-subscript><lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><named-E><N><n>ny</n></N></named-E></upper-bound></section-subscript></section-subscript-LT>)</array-R></R-LT></named-E> )</E-LT></clause></target-update-openmp>

      <C>! perform other work on the device</C>
      <omp>!$omp</omp> <target-openmp>target</target-openmp>      <C>! map(a) is optional here</C>
      <call-stmt>call <procedure-designator><named-E><N><n>other_work</n></N></named-E></procedure-designator>(<arg-spec><arg><named-E><N><n>a</n></N></named-E></arg>, <arg><named-E><N><n>nx</n></N></named-E></arg>, <arg><named-E><N><n>ny</n></N></named-E></arg></arg-spec>)</call-stmt>
      <omp>!$omp</omp> <end-target-openmp>end target</end-target-openmp>

   <omp>!$omp</omp> <end-target-data-openmp>end target data</end-target-data-openmp>

<end-subroutine-stmt>end subroutine</end-subroutine-stmt>
</file></object>
