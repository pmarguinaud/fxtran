<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FREE" source-width="132" openmp="0" openacc="0" openmp-target="1"><file name="devices/target_fort_allocatable_map.2.f90"><C>! @@name:&#009;target_fort_allocatable_map.2</C>
