<program-stmt>program <program-N><N><n>main</n></N></program-N></program-stmt>
  <implicit-none-stmt>implicit none</implicit-none-stmt>

  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>allocatable</attribute-N></attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>a</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec>:</shape-spec>,<shape-spec>:</shape-spec></shape-spec-LT>)</array-spec></EN-decl>, <EN-decl><EN-N><N><n>b</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec>:</shape-spec></shape-spec-LT>)</array-spec></EN-decl>, <EN-decl><EN-N><N><n>c</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec>:</shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_>              :: <EN-decl-LT><EN-decl><EN-N><N><n>x</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><upper-bound><literal-E><l>10</l></literal-E></upper-bound></shape-spec>,<shape-spec><upper-bound><literal-E><l>2</l></literal-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>

  <allocate-stmt>allocate(<arg-spec><arg><named-E><N><n>a</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>2</l></literal-E></element>,<element><literal-E><l>10</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></arg></arg-spec>)</allocate-stmt>

  <omp>!$omp</omp> <target-openmp>target</target-openmp>
     <a-stmt><E-1><named-E><N><n>a</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>x</n></N></named-E></E-2></a-stmt>             <C>! Reshape (or resize) NOT ALLOWED (implicit change)</C>

     <deallocate-stmt>deallocate(<arg-spec><arg><named-E><N><n>a</n></N></named-E></arg></arg-spec>)</deallocate-stmt>     <C>! Allocation status change of &quot;a&quot; NOT ALLOWED.</C>

     <allocate-stmt>allocate(<arg-spec><arg><named-E><N><n>b</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>20</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></arg></arg-spec>)</allocate-stmt>   <C>! Allocation of  b *</C>

     <a-stmt><E-1><named-E><N><n>c</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>10</l></literal-E></E-2></a-stmt>            <C>! Intrinsic assignment allocates c *</C>

     <C>! * Since an explicit deallocation for b and c does not occur before </C>
     <C>! the end of the target region, the PROGRAM BEHAVIOR IS UNSPECIFIED.</C>
  <omp>!$omp</omp> <end-target-openmp>end target</end-target-openmp>

