<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FREE" source-width="132" openmp="0" openacc="0" openmp-target="1"><file name="devices/device.5.f90"><C>! @@name:&#009;device.5</C>
<C>! @@type:&#009;F-free</C>
<C>! @@operation:&#009;compile</C>
<C>! @@expect:&#009;success</C>
<C>! @@version:&#009;omp_5.2</C>
<subroutine-stmt>subroutine <subroutine-N><N><n>async_memcpy</n></N></subroutine-N></subroutine-stmt>
  <use-stmt>use <module-N><N><n>omp_lib</n></N></module-N></use-stmt>
  <use-stmt>use, <module-nature>intrinsic</module-nature>     :: <module-N><N><n>iso_c_binding</n></N></module-N></use-stmt>

  <implicit-none-stmt>implicit none</implicit-none-stmt>

  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>parameter</attribute-N></attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>N</n></N></EN-N> = <init-E><literal-E><l>128</l></literal-E></init-E></EN-decl></EN-decl-LT></T-decl-stmt>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>real</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>target</attribute-N></attribute>       :: <EN-decl-LT><EN-decl><EN-N><N><n>h_buf</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><upper-bound><named-E><N><n>N</n></N></named-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>
  <T-decl-stmt><_T-spec_><derived-T-spec>type(<T-N><N><n>c_ptr</n></N></T-N>)</derived-T-spec></_T-spec_>        :: <EN-decl-LT><EN-decl><EN-N><N><n>c_dbuf</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>c_hbuf</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N><K-selector>(<K-spec><named-E><N><n>c_int</n></N></named-E></K-spec>)</K-selector></intrinsic-T-spec></_T-spec_>     :: <EN-decl-LT><EN-decl><EN-N><N><n>d_dev</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>h_dev</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N><K-selector>(<K-spec><named-E><N><n>c_size_t</n></N></named-E></K-spec>)</K-selector></intrinsic-T-spec></_T-spec_>  :: <EN-decl-LT><EN-decl><EN-N><N><n>dsize</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>

  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>integer</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>i</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>

  <a-stmt><E-1><named-E><N><n>h_dev</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>omp_get_initial_device</n></N><R-LT><parens-R>(<element-LT></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
  <a-stmt><E-1><named-E><N><n>d_dev</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>omp_get_default_device</n></N><R-LT><parens-R>(<element-LT></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
  <a-stmt><E-1><named-E><N><n>dsize</n></N></named-E></E-1> <a>=</a> <E-2><op-E><named-E><N><n>N</n></N></named-E> <op><o>*</o></op> <named-E><N><n>c_sizeof</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>h_buf</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>1</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></element></element-LT>)</parens-R></R-LT></named-E></op-E></E-2></a-stmt>

  <C>! allocate device memory</C>
  <a-stmt><E-1><named-E><N><n>c_dbuf</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>omp_target_alloc</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>dsize</n></N></named-E></element>, <element><named-E><N><n>d_dev</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
  <if-stmt>if (<condition-E><op-E><op><o>.not.</o></op><named-E><N><n>c_associated</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>c_dbuf</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></op-E></condition-E>) <action-stmt><stop-stmt>stop</stop-stmt></action-stmt></if-stmt>
  <a-stmt><E-1><named-E><N><n>c_hbuf</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>c_loc</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>h_buf</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>

  <C>! set up host data</C>
  <a-stmt><E-1><named-E><N><n>h_buf</n></N></named-E></E-1> <a>=</a> <E-2><array-constructor-E>[<ac-value-LT><ac-value><parens-E><iterator>(<iterator-definition-LT><iterator-element><op-E><named-E><N><n>i</n></N></named-E><op><o>*</o></op><literal-E><l>0.1</l></literal-E></op-E></iterator-element>, <iterator-element><V-N><V-N><n>i</n></V-N></V-N> = <literal-E><l>1</l></literal-E></iterator-element>, <iterator-element><named-E><N><n>N</n></N></named-E></iterator-element></iterator-definition-LT>)</iterator></parens-E></ac-value></ac-value-LT>]</array-constructor-E></E-2></a-stmt>

  <C>! copy data from host to device asynchronously</C>
  <if-then-stmt>if (<condition-E><op-E><named-E><N><n>omp_target_memcpy_async</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>c_dbuf</n></N></named-E></element>, <element><named-E><N><n>c_hbuf</n></N></named-E></element>, <element><named-E><N><n>dsize</n></N></named-E></element>, <element><literal-E><l>0</l></literal-E></element>, <element><literal-E><l>0</l></literal-E></element>, <cnt>&amp;</cnt>
                              <element><named-E><N><n>d_dev</n></N></named-E></element>, <element><named-E><N><n>h_dev</n></N></named-E></element>, <element><literal-E><l>0</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E> <op><o>/=</o></op> <literal-E><l>0</l></literal-E></op-E></condition-E>) then</if-then-stmt>
    <stop-stmt>stop</stop-stmt>
  <end-if-stmt>endif</end-if-stmt>

  <C>! do some work here at the same time</C>
  <call-stmt>call <procedure-designator><named-E><N><n>do_work</n></N></named-E></procedure-designator></call-stmt>

  <C>! wait for task completion</C>
  <omp>!$omp</omp> <taskwait-openmp>taskwait</taskwait-openmp>

  <call-stmt>call <procedure-designator><named-E><N><n>omp_target_free</n></N></named-E></procedure-designator>(<arg-spec><arg><named-E><N><n>c_dbuf</n></N></named-E></arg>, <arg><named-E><N><n>d_dev</n></N></named-E></arg></arg-spec>)</call-stmt>

<end-subroutine-stmt>end subroutine</end-subroutine-stmt>
