   <a-stmt><E-1><named-E><N><n>h_cp</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>c_loc</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>h_fp</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
