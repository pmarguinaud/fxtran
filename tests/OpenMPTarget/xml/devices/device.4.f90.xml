   <if-stmt>if(<condition-E><op-E><named-E><N><n>omp_target_is_present</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>h_cp</n></N></named-E></element>, <element><named-E><N><n>targ_dev</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E> <op><o>==</o></op> <literal-E><l>0</l></literal-E></op-E></condition-E>) <cnt>&amp;</cnt>
      <action-stmt><print-stmt>print<format>*</format>, <output-item-LT><output-item><string-E><S>&quot;PASSED 3 of 5&quot;</S></string-E></output-item></output-item-LT></print-stmt></action-stmt></if-stmt>

             <C>! Allocate device memory</C>
   <a-stmt><E-1><named-E><N><n>d_cp</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>omp_target_alloc</n></N><R-LT><parens-R>(<element-LT><element><op-E><named-E><N><n>c_sizeof</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>h_fp</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>1</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></element></element-LT>)</parens-R></R-LT></named-E><op><o>*</o></op><named-E><N><n>size</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>h_fp</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></op-E></element>, <element><named-E><N><n>targ_dev</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>

