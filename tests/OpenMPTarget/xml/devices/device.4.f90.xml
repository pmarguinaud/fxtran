   <if-stmt>if(<condition-E><op-E><named-E><N><n>omp_target_is_present</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>h_cp</n></N></named-E></element>, <element><named-E><N><n>targ_dev</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E> <op><o>/=</o></op> <literal-E><l>0</l></literal-E></op-E></condition-E>) <cnt>&amp;</cnt>
      <action-stmt><print-stmt>print<format>*</format>,<output-item-LT><output-item><string-E><S>&quot;PASSED 4 of 5&quot;</S></string-E></output-item></output-item-LT></print-stmt></action-stmt></if-stmt>

             <C>! copy from host to device via C pointers</C>
   <a-stmt><E-1><named-E><N><n>rc</n></N></named-E></E-1><a>=</a><E-2><named-E><N><n>omp_target_memcpy</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>d_cp</n></N></named-E></element>,       <element><named-E><N><n>h_cp</n></N></named-E></element>,<element><op-E><named-E><N><n>c_sizeof</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>h_fp</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>1</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></element></element-LT>)</parens-R></R-LT></named-E><op><o>*</o></op><named-E><N><n>size</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>h_fp</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></op-E></element>, <cnt>&amp;</cnt>
                        <element><literal-E><l>0</l><K-spec>_<N><n>c_size_t</n></N></K-spec></literal-E></element>, <element><literal-E><l>0</l><K-spec>_<N><n>c_size_t</n></N></K-spec></literal-E></element>,                        <cnt>&amp;</cnt>
