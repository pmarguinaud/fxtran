   <a-stmt><E-1><named-E><N><n>rc</n></N></named-E></E-1><a>=</a><E-2><named-E><N><n>omp_target_associate_ptr</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>h_cp</n></N></named-E></element>,<element><named-E><N><n>d_cp</n></N></named-E></element>,<element><op-E><named-E><N><n>c_sizeof</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>h_fp</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>1</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></element></element-LT>)</parens-R></R-LT></named-E><op><o>*</o></op><named-E><N><n>size</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>h_fp</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></op-E></element>, <cnt>&amp;</cnt>
                               <element><literal-E><l>0</l><K-spec>_<N><n>c_size_t</n></N></K-spec></literal-E></element>,<element><named-E><N><n>targ_dev</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>

