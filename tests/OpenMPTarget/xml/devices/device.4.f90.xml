   <a-stmt><E-1><named-E><N><n>fp_src</n></N></named-E></E-1> <a>=</a> <E-2><array-constructor-E>[<ac-value-LT><ac-value><parens-E><iterator>(<iterator-definition-LT><iterator-element><named-E><N><n>i</n></N></named-E></iterator-element>,<iterator-element><V-N><V-N><n>i</n></V-N></V-N>=<literal-E><l>1</l></literal-E></iterator-element>,<iterator-element><op-E><named-E><N><n>N</n></N></named-E><op><o>+</o></op><literal-E><l>1</l></literal-E></op-E></iterator-element></iterator-definition-LT>)</iterator></parens-E></ac-value></ac-value-LT>]</array-constructor-E></E-2></a-stmt>

