<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FIXED" source-width="72" openmp="0" openacc="0" openmp-target="0"><file name="f77_09_control_goto.f"><C>C     Test: enonces GOTO et ASSIGN</C>
<C>C     Statements couverts: GOTO (inconditionnel), GOTO calcule,</C>
<C>C                          ASSIGN, GOTO assigne, PAUSE, CONTINUE</C>
<m>      </m><program-stmt>PROGRAM <program-N><N><n>GOTOTEST</n></N></program-N></program-stmt>
<m>      </m><T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>INTEGER</T-N></intrinsic-T-spec></_T-spec_> <EN-decl-LT><EN-decl><EN-N><N><n>I</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>ILAB</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>

<C>C     GOTO inconditionnel</C>
<m>      </m><goto-stmt>GOTO <label>100</label></goto-stmt>
<m>      </m><write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'JAMAIS EXECUTE'</S></string-E></output-item></output-item-LT></write-stmt>
<m>  </m><label>100</label><m> </m><continue-stmt>CONTINUE</continue-stmt>

<C>C     GOTO calcule</C>
<m>      </m><a-stmt><E-1><named-E><N><n>I</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>2</l></literal-E></E-2></a-stmt>
<m>      </m><computed-goto-stmt>GOTO (<label-LT><label>10</label>, <label>20</label>, <label>30</label></label-LT>), <test-E><named-E><N><n>I</n></N></named-E></test-E></computed-goto-stmt>
<m>   </m><label>10</label><m> </m><write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'CAS 1'</S></string-E></output-item></output-item-LT></write-stmt>
<m>      </m><goto-stmt>GOTO <label>40</label></goto-stmt>
<m>   </m><label>20</label><m> </m><write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'CAS 2'</S></string-E></output-item></output-item-LT></write-stmt>
<m>      </m><goto-stmt>GOTO <label>40</label></goto-stmt>
<m>   </m><label>30</label><m> </m><write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'CAS 3'</S></string-E></output-item></output-item-LT></write-stmt>
<m>   </m><label>40</label><m> </m><continue-stmt>CONTINUE</continue-stmt>

<C>C     ASSIGN et GOTO assigne</C>
<m>      </m><assign-stmt>ASSIGN <label>200</label> TO <N><n>ILAB</n></N><V></V></assign-stmt>
<m>      </m><assigned-goto-stmt>GOTO <test-E><named-E><N><n>ILAB</n></N></named-E></test-E>, (<label-LT><label>200</label>, <label>300</label></label-LT>)</assigned-goto-stmt>
<m>  </m><label>200</label><m> </m><write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'ETIQUETTE 200'</S></string-E></output-item></output-item-LT></write-stmt>
<m>      </m><goto-stmt>GOTO <label>400</label></goto-stmt>
<m>  </m><label>300</label><m> </m><write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'ETIQUETTE 300'</S></string-E></output-item></output-item-LT></write-stmt>
<m>  </m><label>400</label><m> </m><continue-stmt>CONTINUE</continue-stmt>

<C>C     PAUSE</C>
<m>      </m><pause-stmt>PAUSE <stop-code><S>'APPUYEZ ENTREE'</S></stop-code></pause-stmt>

<m>      </m><end-program-stmt>END</end-program-stmt>
</file></object>
