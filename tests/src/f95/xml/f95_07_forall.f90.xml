<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FREE" source-width="132" openmp="0" openacc="0" openmp-target="0"><file name="f95_07_forall.f90"><C>! Test: FORALL - specifique Fortran 95</C>
<C>! Statements couverts: FORALL (enonce), FORALL (construct) / END FORALL,</C>
<C>!                      FORALL avec masque, FORALL imbrique, FORALL nomme</C>

<program-stmt>PROGRAM <program-N><N><n>FORALLTEST</n></N></program-N></program-stmt>
  <implicit-none-stmt>IMPLICIT NONE</implicit-none-stmt>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>INTEGER</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>I</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>J</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>N</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec></_T-spec_>    :: <EN-decl-LT><EN-decl><EN-N><N><n>A</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><upper-bound><literal-E><l>5</l></literal-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl>, <EN-decl><EN-N><N><n>B</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><upper-bound><literal-E><l>5</l></literal-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl>, <EN-decl><EN-N><N><n>MAT</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><upper-bound><literal-E><l>4</l></literal-E></upper-bound></shape-spec>,<shape-spec><upper-bound><literal-E><l>4</l></literal-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl>, <EN-decl><EN-N><N><n>IMAT</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><upper-bound><literal-E><l>4</l></literal-E></upper-bound></shape-spec>,<shape-spec><upper-bound><literal-E><l>4</l></literal-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>

  <a-stmt><E-1><named-E><N><n>N</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>5</l></literal-E></E-2></a-stmt>
  <a-stmt><E-1><named-E><N><n>A</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>0.0</l></literal-E></E-2></a-stmt>
  <a-stmt><E-1><named-E><N><n>MAT</n></N></named-E></E-1>  <a>=</a> <E-2><literal-E><l>0.0</l></literal-E></E-2></a-stmt>
  <a-stmt><E-1><named-E><N><n>IMAT</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>0.0</l></literal-E></E-2></a-stmt>

  <C>! FORALL enonce (forme courte) - remplissage de tableau</C>
  <forall-stmt>FORALL (<forall-triplet-spec-LT><forall-triplet-spec><V><named-E><N><n>I</n></N></named-E></V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><named-E><N><n>N</n></N></named-E></upper-bound></forall-triplet-spec></forall-triplet-spec-LT>) <action-stmt><a-stmt><E-1><named-E><N><n>A</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><named-E><N><n>REAL</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt></action-stmt></forall-stmt>

  <C>! FORALL enonce avec masque</C>
  <forall-stmt>FORALL (<forall-triplet-spec-LT><forall-triplet-spec><V><named-E><N><n>I</n></N></named-E></V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><named-E><N><n>N</n></N></named-E></upper-bound></forall-triplet-spec></forall-triplet-spec-LT>, <mask-E><op-E><named-E><N><n>A</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E> <op><o>&gt;</o></op> <literal-E><l>2.0</l></literal-E></op-E></mask-E>) <action-stmt><a-stmt><E-1><named-E><N><n>B</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><op-E><named-E><N><n>A</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E> <op><o>*</o></op> <literal-E><l>2.0</l></literal-E></op-E></E-2></a-stmt></action-stmt></forall-stmt>

  <C>! FORALL construct</C>
  <forall-construct-stmt>FORALL (<forall-triplet-spec-LT><forall-triplet-spec><V><named-E><N><n>I</n></N></named-E></V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><literal-E><l>4</l></literal-E></upper-bound></forall-triplet-spec>, <forall-triplet-spec><V><named-E><N><n>J</n></N></named-E></V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><literal-E><l>4</l></literal-E></upper-bound></forall-triplet-spec></forall-triplet-spec-LT>)</forall-construct-stmt>
    <a-stmt><E-1><named-E><N><n>MAT</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element>,<element><named-E><N><n>J</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><named-E><N><n>REAL</n></N><R-LT><parens-R>(<element-LT><element><op-E><named-E><N><n>I</n></N></named-E> <op><o>+</o></op> <op-E><named-E><N><n>J</n></N></named-E> <op><o>-</o></op> <literal-E><l>1</l></literal-E></op-E></op-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
  <end-forall-stmt>END FORALL</end-forall-stmt>

  <C>! FORALL construct avec masque</C>
  <forall-construct-stmt>FORALL (<forall-triplet-spec-LT><forall-triplet-spec><V><named-E><N><n>I</n></N></named-E></V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><literal-E><l>4</l></literal-E></upper-bound></forall-triplet-spec>, <forall-triplet-spec><V><named-E><N><n>J</n></N></named-E></V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><literal-E><l>4</l></literal-E></upper-bound></forall-triplet-spec></forall-triplet-spec-LT>, <mask-E><op-E><named-E><N><n>I</n></N></named-E> <op><o>==</o></op> <named-E><N><n>J</n></N></named-E></op-E></mask-E>)</forall-construct-stmt>
    <a-stmt><E-1><named-E><N><n>IMAT</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element>,<element><named-E><N><n>J</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><literal-E><l>1.0</l></literal-E></E-2></a-stmt>
  <end-forall-stmt>END FORALL</end-forall-stmt>

  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>A</n></N></named-E></output-item></output-item-LT></write-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>IMAT</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>1</l></literal-E></element>,<element><literal-E><l>1</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></output-item>, <output-item><named-E><N><n>IMAT</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>2</l></literal-E></element>,<element><literal-E><l>2</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></output-item>, <output-item><named-E><N><n>IMAT</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>1</l></literal-E></element>,<element><literal-E><l>2</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>

  <C>! FORALL imbrique</C>
  <forall-construct-stmt>FORALL (<forall-triplet-spec-LT><forall-triplet-spec><V><named-E><N><n>I</n></N></named-E></V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><literal-E><l>4</l></literal-E></upper-bound></forall-triplet-spec></forall-triplet-spec-LT>)</forall-construct-stmt>
    <forall-construct-stmt>FORALL (<forall-triplet-spec-LT><forall-triplet-spec><V><named-E><N><n>J</n></N></named-E></V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><literal-E><l>4</l></literal-E></upper-bound></forall-triplet-spec></forall-triplet-spec-LT>, <mask-E><op-E><named-E><N><n>J</n></N></named-E> <op><o>/=</o></op> <named-E><N><n>I</n></N></named-E></op-E></mask-E>)</forall-construct-stmt>
      <a-stmt><E-1><named-E><N><n>MAT</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element>,<element><named-E><N><n>J</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><literal-E><l>0.0</l></literal-E></E-2></a-stmt>
    <end-forall-stmt>END FORALL</end-forall-stmt>
  <end-forall-stmt>END FORALL</end-forall-stmt>

  <C>! FORALL nomme</C>
  <forall-construct-stmt><N><n>MYFORALL</n></N>: FORALL (<forall-triplet-spec-LT><forall-triplet-spec><V><named-E><N><n>I</n></N></named-E></V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><named-E><N><n>N</n></N></named-E></upper-bound></forall-triplet-spec></forall-triplet-spec-LT>)</forall-construct-stmt>
    <a-stmt><E-1><named-E><N><n>A</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><named-E><N><n>REAL</n></N><R-LT><parens-R>(<element-LT><element><op-E><named-E><N><n>N</n></N></named-E> <op><o>+</o></op> <op-E><literal-E><l>1</l></literal-E> <op><o>-</o></op> <named-E><N><n>I</n></N></named-E></op-E></op-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
  <end-forall-stmt>END FORALL <N><n>MYFORALL</n></N></end-forall-stmt>

  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>A</n></N></named-E></output-item></output-item-LT></write-stmt>

<end-program-stmt>END PROGRAM <program-N><N><n>FORALLTEST</n></N></program-N></end-program-stmt>
</file></object>
