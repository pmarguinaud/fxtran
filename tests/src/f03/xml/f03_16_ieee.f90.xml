    <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'IEEE DENORMAL supported:'</S></string-E></output-item>, <output-item><named-E><N><n>SUPPORT</n></N></named-E></output-item></output-item-LT></write-stmt>

    <C>! Valeurs speciales IEEE</C>
