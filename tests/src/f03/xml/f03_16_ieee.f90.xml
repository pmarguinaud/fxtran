    <a-stmt><E-1><named-E><N><n>SUPPORT</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>IEEE_SUPPORT_NAN</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>X</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
