    <a-stmt><E-1><named-E><N><n>X</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>HUGE</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>X</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
    <a-stmt><E-1><named-E><N><n>Y</n></N></named-E></E-1> <a>=</a> <E-2><op-E><named-E><N><n>X</n></N></named-E> <op><o>*</o></op> <literal-E><l>2.0</l></literal-E></op-E></E-2></a-stmt>  <C>! Provoque un overflow</C>
