    <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'+INF:'</S></string-E></output-item>, <output-item><named-E><N><n>X</n></N></named-E></output-item></output-item-LT></write-stmt>

    <a-stmt><E-1><named-E><N><n>X</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>IEEE_VALUE</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>X</n></N></named-E></element>, <element><named-E><N><n>IEEE_NEGATIVE_INF</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
    <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'-INF:'</S></string-E></output-item>, <output-item><named-E><N><n>X</n></N></named-E></output-item></output-item-LT></write-stmt>

    <a-stmt><E-1><named-E><N><n>X</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>IEEE_VALUE</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>X</n></N></named-E></element>, <element><named-E><N><n>IEEE_QUIET_NAN</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
