<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FREE" source-width="132" openmp="0" openacc="0" openmp-target="0"><file name="f03_12_intrinsics.f90"><C>! Test: nouvelles fonctions intrinseques F2003</C>
<C>! Statements couverts: MOVE_ALLOC, NEW_LINE, COMMAND_ARGUMENT_COUNT,</C>
<C>!                      GET_COMMAND_ARGUMENT, GET_COMMAND,</C>
<C>!                      GET_ENVIRONMENT_VARIABLE, IS_IOSTAT_END, IS_IOSTAT_EOR,</C>
<C>!                      SELECTED_CHAR_KIND, EXTENDS_TYPE_OF, SAME_TYPE_AS</C>

<program-stmt>PROGRAM <program-N><N><n>INTRINSICF03</n></N></program-N></program-stmt>
  <use-stmt>USE <module-N><N><n>ISO_FORTRAN_ENV</n></N></module-N></use-stmt>
  <implicit-none-stmt>IMPLICIT NONE</implicit-none-stmt>

  <C>! MOVE_ALLOC</C>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>ALLOCATABLE</attribute-N></attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>SRC</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec>:</shape-spec></shape-spec-LT>)</array-spec></EN-decl>, <EN-decl><EN-N><N><n>DST</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec>:</shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>INTEGER</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>I</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>ARGC</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>ISTAT</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>VLEN</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>VSTATUS</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>CHARACTER</T-N><char-selector>(<char-spec><arg-N n="LEN"><k>LEN</k></arg-N>=<literal-E><l>200</l></literal-E></char-spec>)</char-selector></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>CMD</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>ARG</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>ENVVAL</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>LOGICAL</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>EOR</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>EOF</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>

  <allocate-stmt>ALLOCATE(<arg-spec><arg><named-E><N><n>SRC</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>5</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></arg></arg-spec>)</allocate-stmt>
  <a-stmt><E-1><named-E><N><n>SRC</n></N></named-E></E-1> <a>=</a> <E-2><array-constructor-E>[<ac-value-LT><ac-value><parens-E><iterator>(<iterator-definition-LT><iterator-element><named-E><N><n>REAL</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></iterator-element>, <iterator-element><V-N><V-N><n>I</n></V-N></V-N>=<literal-E><l>1</l></literal-E></iterator-element>,<iterator-element><literal-E><l>5</l></literal-E></iterator-element></iterator-definition-LT>)</iterator></parens-E></ac-value></ac-value-LT>]</array-constructor-E></E-2></a-stmt>
  <call-stmt>CALL <procedure-designator><named-E><N><n>MOVE_ALLOC</n></N></named-E></procedure-designator>(<arg-spec><arg><arg-N n="FROM"><k>FROM</k></arg-N>=<named-E><N><n>SRC</n></N></named-E></arg>, <arg><arg-N n="TO"><k>TO</k></arg-N>=<named-E><N><n>DST</n></N></named-E></arg></arg-spec>)</call-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>ALLOCATED</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>SRC</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></output-item>, <output-item><named-E><N><n>ALLOCATED</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>DST</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>DST</n></N></named-E></output-item></output-item-LT></write-stmt>

  <C>! NEW_LINE</C>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control><string-E><S>'(A)'</S></string-E></io-control></io-control-spec>) <output-item-LT><output-item><op-E><op-E><string-E><S>'LIGNE1'</S></string-E> <op><o>//</o></op> <named-E><N><n>NEW_LINE</n></N><R-LT><parens-R>(<element-LT><element><string-E><S>'A'</S></string-E></element></element-LT>)</parens-R></R-LT></named-E></op-E> <op><o>//</o></op> <string-E><S>'LIGNE2'</S></string-E></op-E></output-item></output-item-LT></write-stmt>

  <C>! COMMAND_ARGUMENT_COUNT</C>
  <a-stmt><E-1><named-E><N><n>ARGC</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>COMMAND_ARGUMENT_COUNT</n></N><R-LT><parens-R>(<element-LT></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'ARGC ='</S></string-E></output-item>, <output-item><named-E><N><n>ARGC</n></N></named-E></output-item></output-item-LT></write-stmt>

  <C>! GET_COMMAND_ARGUMENT</C>
  <call-stmt>CALL <procedure-designator><named-E><N><n>GET_COMMAND_ARGUMENT</n></N></named-E></procedure-designator>(<arg-spec><arg><arg-N n="NUMBER"><k>NUMBER</k></arg-N>=<literal-E><l>0</l></literal-E></arg>, <arg><arg-N n="VALUE"><k>VALUE</k></arg-N>=<named-E><N><n>ARG</n></N></named-E></arg>, <arg><arg-N n="STATUS"><k>STATUS</k></arg-N>=<named-E><N><n>ISTAT</n></N></named-E></arg></arg-spec>)</call-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'PROGRAMME:'</S></string-E></output-item>, <output-item><named-E><N><n>TRIM</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>ARG</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>

  <do-stmt>DO <do-V><named-E><N><n>I</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>, <upper-bound><named-E><N><n>ARGC</n></N></named-E></upper-bound></do-stmt>
    <call-stmt>CALL <procedure-designator><named-E><N><n>GET_COMMAND_ARGUMENT</n></N></named-E></procedure-designator>(<arg-spec><arg><named-E><N><n>I</n></N></named-E></arg>, <arg><named-E><N><n>ARG</n></N></named-E></arg></arg-spec>)</call-stmt>
    <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'ARG'</S></string-E></output-item>, <output-item><named-E><N><n>I</n></N></named-E></output-item>, <output-item><string-E><S>':'</S></string-E></output-item>, <output-item><named-E><N><n>TRIM</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>ARG</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>
  <end-do-stmt>END DO</end-do-stmt>

  <C>! GET_COMMAND</C>
  <call-stmt>CALL <procedure-designator><named-E><N><n>GET_COMMAND</n></N></named-E></procedure-designator>(<arg-spec><arg><arg-N n="COMMAND"><k>COMMAND</k></arg-N>=<named-E><N><n>CMD</n></N></named-E></arg>, <arg><arg-N n="STATUS"><k>STATUS</k></arg-N>=<named-E><N><n>ISTAT</n></N></named-E></arg></arg-spec>)</call-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'COMMANDE:'</S></string-E></output-item>, <output-item><named-E><N><n>TRIM</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>CMD</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>

  <C>! GET_ENVIRONMENT_VARIABLE</C>
  <call-stmt>CALL <procedure-designator><named-E><N><n>GET_ENVIRONMENT_VARIABLE</n></N></named-E></procedure-designator>(<arg-spec><arg><arg-N n="NAME"><k>NAME</k></arg-N>=<string-E><S>'HOME'</S></string-E></arg>, <arg><arg-N n="VALUE"><k>VALUE</k></arg-N>=<named-E><N><n>ENVVAL</n></N></named-E></arg>, <cnt>&amp;</cnt>
                                <arg><arg-N n="LENGTH"><k>LENGTH</k></arg-N>=<named-E><N><n>VLEN</n></N></named-E></arg>, <arg><arg-N n="STATUS"><k>STATUS</k></arg-N>=<named-E><N><n>VSTATUS</n></N></named-E></arg></arg-spec>)</call-stmt>
  <if-stmt>IF (<condition-E><op-E><named-E><N><n>VSTATUS</n></N></named-E> <op><o>==</o></op> <literal-E><l>0</l></literal-E></op-E></condition-E>) <action-stmt><write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'HOME='</S></string-E></output-item>, <output-item><named-E><N><n>TRIM</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>ENVVAL</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt></action-stmt></if-stmt>

  <call-stmt>CALL <procedure-designator><named-E><N><n>GET_ENVIRONMENT_VARIABLE</n></N></named-E></procedure-designator>(<arg-spec><arg><string-E><S>'PATH'</S></string-E></arg>, <arg><named-E><N><n>ENVVAL</n></N></named-E></arg></arg-spec>)</call-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'PATH (debut):'</S></string-E></output-item>, <output-item><named-E><N><n>ENVVAL</n></N><R-LT><array-R>(<section-subscript-LT><section-subscript><lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><literal-E><l>40</l></literal-E></upper-bound></section-subscript></section-subscript-LT>)</array-R></R-LT></named-E></output-item></output-item-LT></write-stmt>

  <C>! IS_IOSTAT_END, IS_IOSTAT_EOR</C>
  <open-stmt>OPEN(<connect-spec-spec><connect-spec><arg-N n="NEWUNIT"><k>NEWUNIT</k></arg-N>=<named-E><N><n>I</n></N></named-E></connect-spec>, <connect-spec><arg-N n="STATUS"><k>STATUS</k></arg-N>=<string-E><S>'SCRATCH'</S></string-E></connect-spec></connect-spec-spec>)</open-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control><named-E><N><n>I</n></N></named-E></io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><literal-E><l>1.0</l></literal-E></output-item>, <output-item><literal-E><l>2.0</l></literal-E></output-item></output-item-LT></write-stmt>
  <rewind-stmt>REWIND(<pos-spec-spec><pos-spec><named-E><N><n>I</n></N></named-E></pos-spec></pos-spec-spec>)</rewind-stmt>
  <read-stmt>READ(<io-control-spec><io-control><named-E><N><n>I</n></N></named-E></io-control>, <io-control>*</io-control>, <io-control><arg-N n="IOSTAT"><k>IOSTAT</k></arg-N>=<named-E><N><n>ISTAT</n></N></named-E></io-control></io-control-spec>) <input-item-LT><input-item><named-E><N><n>ENVVAL</n></N></named-E></input-item></input-item-LT></read-stmt>   <C>! provoque une erreur de conversion</C>
  <a-stmt><E-1><named-E><N><n>EOF</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>IS_IOSTAT_END</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>IOSTAT_END</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
  <a-stmt><E-1><named-E><N><n>EOR</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>IS_IOSTAT_EOR</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>IOSTAT_EOR</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'IS_IOSTAT_END:'</S></string-E></output-item>, <output-item><named-E><N><n>EOF</n></N></named-E></output-item></output-item-LT></write-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><string-E><S>'IS_IOSTAT_EOR:'</S></string-E></output-item>, <output-item><named-E><N><n>EOR</n></N></named-E></output-item></output-item-LT></write-stmt>
  <close-stmt>CLOSE(<close-spec-spec><close-spec><named-E><N><n>I</n></N></named-E></close-spec></close-spec-spec>)</close-stmt>

  <C>! SELECTED_CHAR_KIND</C>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>SELECTED_CHAR_KIND</n></N><R-LT><parens-R>(<element-LT><element><string-E><S>'ASCII'</S></string-E></element></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>SELECTED_CHAR_KIND</n></N><R-LT><parens-R>(<element-LT><element><string-E><S>'DEFAULT'</S></string-E></element></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>

  <deallocate-stmt>DEALLOCATE(<arg-spec><arg><named-E><N><n>DST</n></N></named-E></arg></arg-spec>)</deallocate-stmt>

<end-program-stmt>END PROGRAM <program-N><N><n>INTRINSICF03</n></N></program-N></end-program-stmt>
</file></object>
