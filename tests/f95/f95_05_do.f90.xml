<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FREE" source-width="132" openmp="0" openacc="0" openmp-target="0"><file name="f95_05_do.f90"><C>! Test: nouvelles formes de DO (F90/F95)</C>
<C>! Statements couverts: DO sans etiquette, DO WHILE, DO sans borne (boucle infinie),</C>
<C>!                      EXIT, CYCLE, DO nomme, EXIT/CYCLE avec nom</C>

<program-stmt>PROGRAM <program-N><N><n>DOTEST</n></N></program-N></program-stmt>
  <implicit-none-stmt>IMPLICIT NONE</implicit-none-stmt>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>INTEGER</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>I</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>J</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>N</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>

  <C>! DO sans etiquette (F90+)</C>
  <do-stmt>DO <do-V><named-E><N><n>I</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>, <upper-bound><literal-E><l>5</l></literal-E></upper-bound></do-stmt>
    <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>I</n></N></named-E></output-item></output-item-LT></write-stmt>
  <end-do-stmt>END DO</end-do-stmt>

  <C>! DO WHILE</C>
  <a-stmt><E-1><named-E><N><n>N</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>1</l></literal-E></E-2></a-stmt>
  <do-stmt>DO WHILE (<test-E><op-E><named-E><N><n>N</n></N></named-E> <op><o>&lt;=</o></op> <literal-E><l>10</l></literal-E></op-E></test-E>)</do-stmt>
    <a-stmt><E-1><named-E><N><n>N</n></N></named-E></E-1> <a>=</a> <E-2><op-E><named-E><N><n>N</n></N></named-E> <op><o>*</o></op> <literal-E><l>2</l></literal-E></op-E></E-2></a-stmt>
  <end-do-stmt>END DO</end-do-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>N</n></N></named-E></output-item></output-item-LT></write-stmt>

  <C>! DO infini avec EXIT</C>
  <a-stmt><E-1><named-E><N><n>I</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>0</l></literal-E></E-2></a-stmt>
  <do-stmt>DO</do-stmt>
    <a-stmt><E-1><named-E><N><n>I</n></N></named-E></E-1> <a>=</a> <E-2><op-E><named-E><N><n>I</n></N></named-E> <op><o>+</o></op> <literal-E><l>1</l></literal-E></op-E></E-2></a-stmt>
    <if-stmt>IF (<condition-E><op-E><named-E><N><n>I</n></N></named-E> <op><o>&gt;=</o></op> <literal-E><l>5</l></literal-E></op-E></condition-E>) <action-stmt><exit-stmt>EXIT</exit-stmt></action-stmt></if-stmt>
  <end-do-stmt>END DO</end-do-stmt>

  <C>! CYCLE dans une boucle</C>
  <do-stmt>DO <do-V><named-E><N><n>I</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>, <upper-bound><literal-E><l>10</l></literal-E></upper-bound></do-stmt>
    <if-stmt>IF (<condition-E><op-E><named-E><N><n>MOD</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element>, <element><literal-E><l>2</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E> <op><o>==</o></op> <literal-E><l>0</l></literal-E></op-E></condition-E>) <action-stmt><cycle-stmt>CYCLE</cycle-stmt></action-stmt></if-stmt>
    <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>I</n></N></named-E></output-item></output-item-LT></write-stmt>  <C>! imprime seulement les impairs</C>
  <end-do-stmt>END DO</end-do-stmt>

  <C>! DO nomme avec EXIT/CYCLE sur nom</C>
  <do-stmt><N><n>OUTER</n></N>: DO <do-V><named-E><N><n>I</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>, <upper-bound><literal-E><l>5</l></literal-E></upper-bound></do-stmt>
    <do-stmt><N><n>INNER</n></N>: DO <do-V><named-E><N><n>J</n></N></named-E></do-V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>, <upper-bound><literal-E><l>5</l></literal-E></upper-bound></do-stmt>
      <if-stmt>IF (<condition-E><op-E><named-E><N><n>J</n></N></named-E> <op><o>==</o></op> <literal-E><l>3</l></literal-E></op-E></condition-E>) <action-stmt><cycle-stmt>CYCLE <N><n>INNER</n></N></cycle-stmt></action-stmt></if-stmt>
      <if-stmt>IF (<condition-E><op-E><named-E><N><n>I</n></N></named-E> <op><o>==</o></op> <literal-E><l>4</l></literal-E></op-E></condition-E>) <action-stmt><exit-stmt>EXIT <N><n>OUTER</n></N></exit-stmt></action-stmt></if-stmt>
      <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>I</n></N></named-E></output-item>, <output-item><named-E><N><n>J</n></N></named-E></output-item></output-item-LT></write-stmt>
    <end-do-stmt>END DO <N><n>INNER</n></N></end-do-stmt>
  <end-do-stmt>END DO <N><n>OUTER</n></N></end-do-stmt>

  <C>! DO WHILE nomme</C>
  <a-stmt><E-1><named-E><N><n>N</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>0</l></literal-E></E-2></a-stmt>
  <do-stmt><N><n>MYLOOP</n></N>: DO WHILE (<test-E><op-E><named-E><N><n>N</n></N></named-E> <op><o>&lt;</o></op> <literal-E><l>3</l></literal-E></op-E></test-E>)</do-stmt>
    <a-stmt><E-1><named-E><N><n>N</n></N></named-E></E-1> <a>=</a> <E-2><op-E><named-E><N><n>N</n></N></named-E> <op><o>+</o></op> <literal-E><l>1</l></literal-E></op-E></E-2></a-stmt>
  <end-do-stmt>END DO <N><n>MYLOOP</n></N></end-do-stmt>

<end-program-stmt>END PROGRAM <program-N><N><n>DOTEST</n></N></program-N></end-program-stmt>
</file></object>
