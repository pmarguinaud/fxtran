<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FREE" source-width="132" openmp="0" openacc="0" openmp-target="0"><file name="f95_10_arrays.f90"><C>! Test: operations tableaux F90/F95</C>
<C>! Statements couverts: constructeurs de tableaux (/ /), sections de tableaux,</C>
<C>!                      operations whole-array, tableaux assumes-shape (assumed-shape),</C>
