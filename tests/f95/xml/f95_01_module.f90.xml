  <end-subroutine-stmt>END SUBROUTINE <subroutine-N><N><n>GREET</n></N></subroutine-N></end-subroutine-stmt>

<end-module-stmt>END MODULE <module-N><N><n>STRMOD</n></N></module-N></end-module-stmt>


<program-stmt>PROGRAM <program-N><N><n>MODTEST</n></N></program-N></program-stmt>
  <C>! USE sans restriction</C>
  <use-stmt>USE <module-N><N><n>MATHMOD</n></N></module-N></use-stmt>
  <C>! USE avec ONLY</C>
  <use-stmt>USE <module-N><N><n>STRMOD</n></N></module-N>, ONLY : <rename-LT><rename><use-N><N><n>GREET</n></N></use-N></rename></rename-LT></use-stmt>
  <C>! USE avec renommage</C>
  <use-stmt>USE <module-N><N><n>MATHMOD</n></N></module-N>, <rename-LT><rename><use-N><N><n>MYPI</n></N></use-N> =&gt; <N><N><n>PI</n></N></N></rename></rename-LT></use-stmt>

  <implicit-none-stmt>IMPLICIT NONE</implicit-none-stmt>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>X</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>Y</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>

  <a-stmt><E-1><named-E><N><n>X</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>SQUARE</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>3.0</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
  <a-stmt><E-1><named-E><N><n>Y</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>ADD</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>1.0</l></literal-E></element>, <element><literal-E><l>2.0</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>PI</n></N></named-E></output-item>, <output-item><named-E><N><n>TWOPI</n></N></named-E></output-item>, <output-item><named-E><N><n>MYPI</n></N></named-E></output-item></output-item-LT></write-stmt>
  <call-stmt>CALL <procedure-designator><named-E><N><n>GREET</n></N></named-E></procedure-designator>(<arg-spec><arg><string-E><S>'BONJOUR'</S></string-E></arg></arg-spec>)</call-stmt>
<end-program-stmt>END PROGRAM <program-N><N><n>MODTEST</n></N></program-N></end-program-stmt>
