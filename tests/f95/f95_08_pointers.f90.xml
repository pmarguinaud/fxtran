<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FREE" source-width="132" openmp="0" openacc="0" openmp-target="0"><file name="f95_08_pointers.f90"><C>! Test: pointeurs et allocation dynamique</C>
<C>! Statements couverts: POINTER, TARGET, ALLOCATABLE,</C>
<C>!                      ALLOCATE, DEALLOCATE, NULLIFY,</C>
<C>!                      ASSOCIATED, ALLOCATED (fonctions intrinseques)</C>

<program-stmt>PROGRAM <program-N><N><n>PTRTEST</n></N></program-N></program-stmt>
  <implicit-none-stmt>IMPLICIT NONE</implicit-none-stmt>

  <C>! Pointeurs scalaires</C>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>POINTER</attribute-N></attribute>    :: <EN-decl-LT><EN-decl><EN-N><N><n>P</n></N></EN-N> =&gt; <init-E><named-E><N><n>NULL</n></N><R-LT><parens-R>(<element-LT></element-LT>)</parens-R></R-LT></named-E></init-E></EN-decl></EN-decl-LT></T-decl-stmt>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>TARGET</attribute-N></attribute>     :: <EN-decl-LT><EN-decl><EN-N><N><n>X</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>Y</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>

  <C>! Pointeurs sur tableaux</C>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>POINTER</attribute-N></attribute>    :: <EN-decl-LT><EN-decl><EN-N><N><n>VPTR</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec>:</shape-spec></shape-spec-LT>)</array-spec> =&gt; <init-E><named-E><N><n>NULL</n></N><R-LT><parens-R>(<element-LT></element-LT>)</parens-R></R-LT></named-E></init-E></EN-decl></EN-decl-LT></T-decl-stmt>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>TARGET</attribute-N></attribute>     :: <EN-decl-LT><EN-decl><EN-N><N><n>VTGT</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec><upper-bound><literal-E><l>5</l></literal-E></upper-bound></shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>

  <C>! Tableaux allocatables</C>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>ALLOCATABLE</attribute-N></attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>AVEC</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec>:</shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>
  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>ALLOCATABLE</attribute-N></attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>MAT</n></N></EN-N><array-spec>(<shape-spec-LT><shape-spec>:</shape-spec>,<shape-spec>:</shape-spec></shape-spec-LT>)</array-spec></EN-decl></EN-decl-LT></T-decl-stmt>

  <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>INTEGER</T-N></intrinsic-T-spec></_T-spec_> :: <EN-decl-LT><EN-decl><EN-N><N><n>I</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>ISTAT</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>

  <C>! Association de pointeur</C>
  <a-stmt><E-1><named-E><N><n>X</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>3.14</l></literal-E></E-2></a-stmt>
  <pointer-a-stmt><E-1><named-E><N><n>P</n></N></named-E></E-1> <a>=&gt;</a> <E-2><named-E><N><n>X</n></N></named-E></E-2></pointer-a-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>P</n></N></named-E></output-item>, <output-item><named-E><N><n>ASSOCIATED</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>P</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>

  <C>! Reassociation</C>
  <a-stmt><E-1><named-E><N><n>Y</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>2.71</l></literal-E></E-2></a-stmt>
  <pointer-a-stmt><E-1><named-E><N><n>P</n></N></named-E></E-1> <a>=&gt;</a> <E-2><named-E><N><n>Y</n></N></named-E></E-2></pointer-a-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>P</n></N></named-E></output-item></output-item-LT></write-stmt>

  <C>! NULLIFY</C>
  <nullify-stmt>NULLIFY(<arg-spec><arg><named-E><N><n>P</n></N></named-E></arg></arg-spec>)</nullify-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>ASSOCIATED</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>P</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>

  <C>! Pointeur sur tableau</C>
  <a-stmt><E-1><named-E><N><n>VTGT</n></N></named-E></E-1> <a>=</a> <E-2><array-constructor-E>[<ac-value-LT><ac-value><literal-E><l>1.0</l></literal-E></ac-value>, <ac-value><literal-E><l>2.0</l></literal-E></ac-value>, <ac-value><literal-E><l>3.0</l></literal-E></ac-value>, <ac-value><literal-E><l>4.0</l></literal-E></ac-value>, <ac-value><literal-E><l>5.0</l></literal-E></ac-value></ac-value-LT>]</array-constructor-E></E-2></a-stmt>
  <pointer-a-stmt><E-1><named-E><N><n>VPTR</n></N></named-E></E-1> <a>=&gt;</a> <E-2><named-E><N><n>VTGT</n></N></named-E></E-2></pointer-a-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>VPTR</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>3</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>

  <C>! Pointeur sur sous-tableau (section)</C>
  <pointer-a-stmt><E-1><named-E><N><n>VPTR</n></N></named-E></E-1> <a>=&gt;</a> <E-2><named-E><N><n>VTGT</n></N><R-LT><array-R>(<section-subscript-LT><section-subscript><lower-bound><literal-E><l>2</l></literal-E></lower-bound>:<upper-bound><literal-E><l>4</l></literal-E></upper-bound></section-subscript></section-subscript-LT>)</array-R></R-LT></named-E></E-2></pointer-a-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>SIZE</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>VPTR</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>

  <C>! ALLOCATE scalaire via pointeur</C>
  <allocate-stmt>ALLOCATE(<arg-spec><arg><named-E><N><n>P</n></N></named-E></arg></arg-spec>)</allocate-stmt>
  <a-stmt><E-1><named-E><N><n>P</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>42.0</l></literal-E></E-2></a-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>P</n></N></named-E></output-item></output-item-LT></write-stmt>
  <deallocate-stmt>DEALLOCATE(<arg-spec><arg><named-E><N><n>P</n></N></named-E></arg></arg-spec>)</deallocate-stmt>

  <C>! ALLOCATE tableau via pointeur</C>
  <allocate-stmt>ALLOCATE(<arg-spec><arg><named-E><N><n>VPTR</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>10</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></arg>, <arg><arg-N n="STAT"><k>STAT</k></arg-N>=<named-E><N><n>ISTAT</n></N></named-E></arg></arg-spec>)</allocate-stmt>
  <if-then-stmt>IF (<condition-E><op-E><named-E><N><n>ISTAT</n></N></named-E> <op><o>==</o></op> <literal-E><l>0</l></literal-E></op-E></condition-E>) THEN</if-then-stmt>
    <forall-stmt>FORALL (<forall-triplet-spec-LT><forall-triplet-spec><V><named-E><N><n>I</n></N></named-E></V> = <lower-bound><literal-E><l>1</l></literal-E></lower-bound>:<upper-bound><literal-E><l>10</l></literal-E></upper-bound></forall-triplet-spec></forall-triplet-spec-LT>) <action-stmt><a-stmt><E-1><named-E><N><n>VPTR</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><named-E><N><n>REAL</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>I</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt></action-stmt></forall-stmt>
    <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>VPTR</n></N></named-E></output-item></output-item-LT></write-stmt>
  <end-if-stmt>END IF</end-if-stmt>
  <deallocate-stmt>DEALLOCATE(<arg-spec><arg><named-E><N><n>VPTR</n></N></named-E></arg></arg-spec>)</deallocate-stmt>

  <C>! ALLOCATABLE</C>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>ALLOCATED</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>AVEC</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>
  <allocate-stmt>ALLOCATE(<arg-spec><arg><named-E><N><n>AVEC</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>5</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></arg></arg-spec>)</allocate-stmt>
  <a-stmt><E-1><named-E><N><n>AVEC</n></N></named-E></E-1> <a>=</a> <E-2><array-constructor-E>[<ac-value-LT><ac-value><literal-E><l>1.0</l></literal-E></ac-value>, <ac-value><literal-E><l>2.0</l></literal-E></ac-value>, <ac-value><literal-E><l>3.0</l></literal-E></ac-value>, <ac-value><literal-E><l>4.0</l></literal-E></ac-value>, <ac-value><literal-E><l>5.0</l></literal-E></ac-value></ac-value-LT>]</array-constructor-E></E-2></a-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>ALLOCATED</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>AVEC</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></output-item>, <output-item><named-E><N><n>SIZE</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>AVEC</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>
  <deallocate-stmt>DEALLOCATE(<arg-spec><arg><named-E><N><n>AVEC</n></N></named-E></arg></arg-spec>)</deallocate-stmt>

  <C>! ALLOCATE tableau 2D</C>
  <allocate-stmt>ALLOCATE(<arg-spec><arg><named-E><N><n>MAT</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>3</l></literal-E></element>,<element><literal-E><l>4</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></arg>, <arg><arg-N n="STAT"><k>STAT</k></arg-N>=<named-E><N><n>ISTAT</n></N></named-E></arg></arg-spec>)</allocate-stmt>
  <a-stmt><E-1><named-E><N><n>MAT</n></N></named-E></E-1> <a>=</a> <E-2><literal-E><l>0.0</l></literal-E></E-2></a-stmt>
  <a-stmt><E-1><named-E><N><n>MAT</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>2</l></literal-E></element>,<element><literal-E><l>3</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></E-1> <a>=</a> <E-2><literal-E><l>99.0</l></literal-E></E-2></a-stmt>
  <write-stmt>WRITE(<io-control-spec><io-control>*</io-control>,<io-control>*</io-control></io-control-spec>) <output-item-LT><output-item><named-E><N><n>MAT</n></N><R-LT><parens-R>(<element-LT><element><literal-E><l>2</l></literal-E></element>,<element><literal-E><l>3</l></literal-E></element></element-LT>)</parens-R></R-LT></named-E></output-item></output-item-LT></write-stmt>
  <deallocate-stmt>DEALLOCATE(<arg-spec><arg><named-E><N><n>MAT</n></N></named-E></arg></arg-spec>)</deallocate-stmt>

<end-program-stmt>END PROGRAM <program-N><N><n>PTRTEST</n></N></program-N></end-program-stmt>
</file></object>
