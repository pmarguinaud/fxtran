    <T-decl-stmt><_T-spec_><intrinsic-T-spec><T-N>REAL</T-N></intrinsic-T-spec></_T-spec_>, <attribute><attribute-N>INTENT</attribute-N>(<intent-spec>IN</intent-spec>)</attribute> :: <EN-decl-LT><EN-decl><EN-N><N><n>X</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>LO</n></N></EN-N></EN-decl>, <EN-decl><EN-N><N><n>HI</n></N></EN-N></EN-decl></EN-decl-LT></T-decl-stmt>
    <a-stmt><E-1><named-E><N><n>CLAMP</n></N></named-E></E-1> <a>=</a> <E-2><named-E><N><n>MIN</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>MAX</n></N><R-LT><parens-R>(<element-LT><element><named-E><N><n>X</n></N></named-E></element>, <element><named-E><N><n>LO</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></element>, <element><named-E><N><n>HI</n></N></named-E></element></element-LT>)</parens-R></R-LT></named-E></E-2></a-stmt>
