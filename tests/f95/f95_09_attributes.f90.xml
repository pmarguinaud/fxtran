<?xml version="1.0"?><object xmlns="http://fxtran.net/#syntax" source-form="FREE" source-width="132" openmp="0" openacc="0" openmp-target="0"><file name="f95_09_attributes.f90"><C>! Test: attributs de procedures et d'arguments</C>
